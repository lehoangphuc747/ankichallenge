---
import Layout from "../../layouts/Layout.astro";
import AdminCalendar from "../../components/admin/AdminCalendar";

// 🔒 BẢO VỆ: Chỉ cho phép truy cập khi chạy localhost (dev)
// Khi deploy lên production, sẽ tự động redirect về trang chủ
if (import.meta.env.PROD) {
  return Astro.redirect("/", 302);
}
---

<Layout title="Admin Check-in - Anki Challenge">
  <main class="min-h-screen bg-slate-50 py-4 px-4">
    <div class="max-w-7xl mx-auto space-y-4">
      
      <!-- Top Bar: Title, Challenge Select, Actions -->
      <div class="flex flex-col md:flex-row md:items-center justify-between bg-white p-4 rounded-xl shadow-sm border border-gray-100 gap-4">
        <div>
          <h1 class="text-2xl font-bold bg-gradient-to-r from-green-600 to-blue-600 bg-clip-text text-transparent flex items-center gap-2">
            ✅ Quản lý Check-in
          </h1>
          <p class="text-xs font-medium text-gray-500 mt-1">Click vào hàng để cập nhật trạng thái</p>
        </div>
        
        <div class="flex flex-wrap items-center gap-3">
          <select id="challengeSelect" class="py-1.5 px-3 text-sm border-2 border-blue-200 rounded-lg font-semibold text-gray-700 bg-white hover:border-blue-300 focus:ring-2 focus:ring-blue-500 outline-none transition-all">
            <option value="">Đang tải...</option>
          </select>
          <a href="/" class="py-1.5 px-3 text-sm bg-indigo-50 text-indigo-700 border border-indigo-200 rounded-lg hover:bg-indigo-100 transition-colors flex items-center gap-1.5 font-semibold shadow-sm">
            🏆 Leaderboard
          </a>
          <a href="/admin" class="py-1.5 px-3 text-sm bg-gray-100 text-gray-700 border border-gray-200 rounded-lg hover:bg-gray-200 transition-colors flex items-center gap-1.5 font-semibold shadow-sm">
            ← Dashboard
          </a>
        </div>
      </div>

      <!-- Toast Notification -->
      <div id="toast" class="fixed top-4 right-4 z-50 hidden">
        <div class="bg-white rounded-lg shadow-xl border-l-4 border-green-500 p-3 min-w-[250px] transform transition-all duration-300 flex items-center">
          <div class="text-xl mr-3" id="toastIcon">✅</div>
          <div>
            <p class="font-bold text-sm text-gray-900" id="toastTitle">Thành công!</p>
            <p class="text-xs text-gray-600" id="toastMessage">Đã lưu thay đổi</p>
          </div>
        </div>
      </div>

      <!-- Loading -->
      <div id="loading" class="text-center py-8">
        <div class="inline-block bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
          <p class="text-base font-bold text-gray-700 flex items-center gap-2"><span>⏳</span> Đang tải dữ liệu...</p>
        </div>
      </div>

      <div id="content" class="hidden space-y-4">
        <!-- Main Controls Row: Calendar, Search, Stats -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
          
          <!-- Left: Calendar & Search -->
          <div class="lg:col-span-7 xl:col-span-8 flex flex-col gap-4">
            <div class="bg-white p-3 rounded-xl shadow-sm border border-gray-100 flex flex-col sm:flex-row items-center gap-3">
              <div class="flex-shrink-0">
                 <AdminCalendar client:visible />
                 <input type="hidden" id="selectedDate" />
              </div>
              
              <div class="flex-1 w-full relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                  <span class="text-gray-400">🔍</span>
                </div>
                <input type="text" id="searchInput" placeholder="Tìm tên/Discord..." class="w-full pl-9 pr-9 py-2 border-2 border-gray-200 rounded-lg text-sm font-medium text-gray-700 focus:border-blue-400 focus:ring-2 focus:ring-blue-500/20 outline-none transition-all" />
                <button id="clearSearch" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 focus:outline-none" title="Xóa tìm kiếm">✕</button>
              </div>
            </div>
          </div>

          <!-- Right: Compact Stats -->
          <div class="lg:col-span-5 xl:col-span-4 bg-white p-3 rounded-xl shadow-sm border border-gray-100 flex flex-col justify-center">
              <div class="grid grid-cols-2 gap-3">
                <div class="bg-green-50 p-2.5 rounded-lg border border-green-100 flex items-center justify-between shadow-sm">
                  <span class="text-xs font-bold text-green-700">Đã Check</span>
                  <span class="text-xl font-black text-green-600" id="checkedCount">0</span>
                </div>
                <div class="bg-orange-50 p-2.5 rounded-lg border border-orange-100 flex items-center justify-between shadow-sm">
                  <span class="text-xs font-bold text-orange-700">Chưa Check</span>
                  <span class="text-xl font-black text-orange-600" id="uncheckedCount">0</span>
                </div>
                <div class="bg-blue-50 p-2.5 rounded-lg border border-blue-100 flex items-center justify-between shadow-sm">
                  <span class="text-xs font-bold text-blue-700">Tỷ lệ</span>
                  <span class="text-xl font-black text-blue-600" id="checkinRate">0%</span>
                </div>
                <div class="bg-purple-50 p-2.5 rounded-lg border border-purple-100 flex items-center justify-between shadow-sm">
                  <span class="text-xs font-bold text-purple-700">Ngày</span>
                  <span class="text-xl font-black text-purple-600" id="dayCounter">-</span>
                </div>
              </div>
          </div>
        </div>

        <!-- Check-in Lists - 2 Columns -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
          <!-- Left Column: Unchecked Section -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex flex-col h-[min(800px,calc(100vh-220px))] relative">
            <div class="bg-orange-50 border-b border-orange-100 px-4 py-2.5 flex items-center justify-between shrink-0 sticky top-0 z-10 shadow-sm">
              <h2 class="text-sm font-bold text-orange-800 flex items-center gap-2">
                <span>⏳</span> Chưa check-in (<span id="uncheckedHeader">0</span>)
              </h2>
              <button id="copyDiscordNamesBtn" class="px-2.5 py-1 bg-white text-orange-600 border border-orange-200 hover:bg-orange-100 hover:text-orange-700 rounded text-xs font-bold transition-colors flex items-center gap-1 shadow-sm">
                📋 Copy Discord
              </button>
            </div>
            <div id="uncheckedList" class="divide-y divide-gray-100 flex-1 overflow-y-auto bg-gray-50/50">
              <!-- Will be populated by JavaScript -->
            </div>
          </div>

          <!-- Right Column: Checked Section -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex flex-col h-[min(800px,calc(100vh-220px))] relative">
            <div class="bg-green-50 border-b border-green-100 px-4 py-2.5 shrink-0 flex items-center sticky top-0 z-10 shadow-sm">
              <h2 class="text-sm font-bold text-green-800 flex items-center gap-2">
                <span>✅</span> Đã check-in (<span id="checkedHeader">0</span>)
              </h2>
            </div>
            <div id="checkedList" class="divide-y divide-gray-100 flex-1 overflow-y-auto bg-gray-50/50">
              <!-- Will be populated by JavaScript -->
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Import và khởi chạy checkin admin module
  import { initCheckin } from "../../scripts/admin/checkin";
  initCheckin();
</script>

<style>
  @keyframes slideIn {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  #toast:not(.hidden) {
    animation: slideIn 0.3s ease-out;
  }

  .checkin-item:focus {
    outline: none;
  }

  /* Focus state - đã được xử lý bằng classes trong JavaScript */
  /* Giữ lại style này để đảm bảo không có conflict */
  .checkin-item {
    transition: all 0.2s ease-in-out;
  }
</style>
