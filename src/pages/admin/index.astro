<script>
  // Load and display stats
  async function loadStats() {
    // Chỉ chạy nếu phần tử tồn tại trên trang (người dùng đã đăng nhập)
    const totalMembersEl = document.getElementById("totalMembers");
    if (!totalMembersEl) return;

    try {
      // Load metadata trước để lấy lastUpdated làm cache-buster
      // Đảm bảo luôn lấy dữ liệu mới nhất từ server
      const metadataResponse = await fetch(
        "/api/data/metadata?v=" + Date.now(),
      );
      const metadata = await metadataResponse.json();
      const cacheBuster = metadata?.lastUpdated
        ? "?v=" + new Date(metadata.lastUpdated).getTime()
        : "?v=" + Date.now();

      const [usersResponse, challengesResponse] = await Promise.all([
        fetch("/api/data/users" + cacheBuster),
        fetch("/api/data/challenges" + cacheBuster),
      ]);

      const usersData = await usersResponse.json();
      const challengesData = await challengesResponse.json();

      const today = new Date().toISOString().split("T")[0];
      
      let activeChallengeId = '2'; // fallback
      for (const [id, data] of Object.entries(challengesData as Record<string, any>)) {
          if (today >= data.start && today <= data.end) {
              activeChallengeId = id;
              break;
          }
      }

      let prefix = '08';
      if (activeChallengeId === '1') prefix = '08';
      if (activeChallengeId === '2') prefix = '09';
      if (activeChallengeId === '3') prefix = '10';

      const studyRecordsResponse = await fetch(`/api/data/records_${prefix}` + cacheBuster);
      const studyRecordsData = await studyRecordsResponse.json();

      // Total members
      const totalMembers = usersData.data?.length || 0;
      const activeMembers =
        usersData.data?.filter((u) => !u.hidden).length || 0;

      // Today's check-ins
      const todayRecords = studyRecordsData[today] || {};
      const todayCheckins = Object.keys(todayRecords).length;

      // Days left in challenge
      const endDate = new Date("2025-12-21");
      const currentDate = new Date();
      const daysLeft = Math.max(
        0,
        Math.ceil(
          (endDate.getTime() - currentDate.getTime()) / (1000 * 60 * 60 * 24),
        ),
      );

      // Update UI
      totalMembersEl.textContent = totalMembers.toString();
      
      const activeMembersEl = document.getElementById("activeMembers");
      if (activeMembersEl) activeMembersEl.textContent = activeMembers.toString();
      
      const todayCheckinsEl = document.getElementById("todayCheckins");
      if (todayCheckinsEl) todayCheckinsEl.textContent = todayCheckins.toString();
      
      const daysLeftEl = document.getElementById("daysLeft");
      if (daysLeftEl) daysLeftEl.textContent = daysLeft.toString();

      // Last update
      const lastUpdateEl = document.getElementById("lastUpdate");
      if (lastUpdateEl && metadata.lastUpdated) {
        const lastUpdateDate = new Date(metadata.lastUpdated);
        lastUpdateEl.textContent = lastUpdateDate.toLocaleString("vi-VN");
      }
    } catch (error) {
      console.error("Error loading stats:", error);
    }
  }

  // Load & render Discord Login History
  async function loadLoginHistory() {
    const tbody = document.getElementById("discordLoginHistoryBody");
    if (!tbody) return;

    try {
      const res = await fetch("/api/data/login_history?v=" + Date.now());
      if (!res.ok) {
        tbody.innerHTML = `<tr><td colspan="4" class="py-8 text-center text-gray-400 font-medium">Chưa có lượt đăng nhập Discord nào được ghi nhận</td></tr>`;
        return;
      }
      const historyList = await res.json();
      if (!Array.isArray(historyList) || historyList.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" class="py-8 text-center text-gray-400 font-medium">Chưa có lượt đăng nhập Discord nào được ghi nhận</td></tr>`;
        return;
      }

      tbody.innerHTML = historyList.map((item: any) => {
        const timeAgo = new Date(item.loggedAt).toLocaleString("vi-VN", { timeZone: "Asia/Ho_Chi_Minh" });
        const mappedBadge = item.memberId 
          ? `<span class="px-2.5 py-1 bg-emerald-50 text-emerald-700 font-bold text-xs rounded-lg border border-emerald-200 inline-flex items-center gap-1">
              <span>✅</span> ID #${item.memberId} - ${item.memberName || 'Thành viên'}
             </span>`
          : `<span class="px-2.5 py-1 bg-amber-50 text-amber-700 font-bold text-xs rounded-lg border border-amber-200 inline-flex items-center gap-1">
              <span>⚠️</span> Chưa ghép nối
             </span>`;

        return `
          <tr class="hover:bg-gray-50/80 transition-colors">
            <td class="py-3.5 px-2">
              <div class="flex items-center gap-3">
                <img src="${item.avatar}" class="w-9 h-9 rounded-full bg-gray-100 object-cover flex-shrink-0" alt="" />
                <div>
                  <div class="font-bold text-gray-900 leading-snug">${item.displayName}</div>
                  <div class="text-xs text-gray-400 font-mono">@${item.username} (ID: ${item.discordId})</div>
                </div>
              </div>
            </td>
            <td class="py-3.5 px-2 text-gray-600 text-xs font-mono">${item.email || '<span class="text-gray-300">Không có email</span>'}</td>
            <td class="py-3.5 px-2">${mappedBadge}</td>
            <td class="py-3.5 px-2 text-right font-semibold text-xs text-gray-500">${timeAgo}</td>
          </tr>
        `;
      }).join("");
    } catch (e) {
      console.error("Error loading login history:", e);
      tbody.innerHTML = `<tr><td colspan="4" class="py-8 text-center text-red-500 font-medium">Không thể tải dữ liệu nhật ký</td></tr>`;
    }
  }

  document.getElementById("refreshLoginHistoryBtn")?.addEventListener("click", loadLoginHistory);

  // Load stats & login history on page load
  loadStats();
  loadLoginHistory();
</script>

<style>
  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .aurora-button {
    background: linear-gradient(45deg, #667eea 0%, #764ba2 100%);
    background-size: 200% 200%;
    animation: gradient 3s ease infinite;
  }
</style>

