                Mật khẩu Admin
              </label>
              <input
                id="password"
                name="password"
                type="password"
                required
                class="w-full px-4 py-3 border-2 border-black focus:outline-none focus:ring-3 focus:ring-primary/20 text-lg font-medium text-gray-900 bg-white tracking-widest"
                placeholder="••••••••"
              />
            </div>

            <div>
              <button
                type="submit"
                class="w-full aurora-button font-black tracking-wider text-base cursor-pointer"
