---
import Layout from "../../layouts/Layout.astro";

// Lấy password từ env (hỗ trợ cả Astro env và Node process env)
const adminPassword = import.meta.env.ADMIN_PASSWORD || 
                      (typeof process !== 'undefined' ? process.env.ADMIN_PASSWORD : undefined) || 
                      'admin123';

let error = "";
const method = Astro.request.method;

if (method === "POST") {
  try {
    const data = await Astro.request.formData();
    const action = data.get("action");
    
    if (action === "logout") {
      Astro.cookies.delete("admin_session", { path: "/" });
      return Astro.redirect("/admin");
    } else {
      const password = data.get("password");
      if (password === adminPassword) {
        // Thiết lập cookie session có thời hạn 7 ngày
        Astro.cookies.set("admin_session", adminPassword, {
          path: "/",
          httpOnly: true,
          secure: true,
          sameSite: "strict",
          maxAge: 60 * 60 * 24 * 7,
        });
        return Astro.redirect("/admin");
      } else {
        error = "Mật khẩu quản trị không chính xác!";
      }
    }
  } catch (e) {
    error = "Đã xảy ra lỗi hệ thống, vui lòng thử lại!";
  }
}

const sessionCookie = Astro.cookies.get("admin_session")?.value;
const isAuthenticated = sessionCookie === adminPassword;
---

{isAuthenticated ? (
  <Layout title="Admin Dashboard - Anki Challenge">
    <main class="min-h-screen bg-gray-50/50 py-10 px-6">
      <div class="max-w-5xl mx-auto space-y-10">
        <!-- Header -->
        <div class="flex items-center justify-between border-b-2 border-black pb-6 mb-6">
