) : (
  <Layout title="Đăng nhập Admin - Anki Challenge">
    <main class="min-h-screen bg-gray-50/50 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
      <div class="max-w-md w-full space-y-8">
        <div class="aurora-card p-8 bg-white relative">
          <!-- Accent indicator -->
          <div class="absolute top-0 left-0 right-0 h-2 bg-primary"></div>
          
          <div class="text-center mb-6">
            <h2 class="text-3xl font-extrabold text-gray-900 tracking-tight mb-2 uppercase">
              ADMIN LOGIN
            </h2>
            <p class="text-sm font-semibold uppercase tracking-wider text-secondary">
              Anki Challenge Dashboard
            </p>
          </div>

          {error && (
            <div class="bg-red-50 border-2 border-red-500 text-red-700 px-4 py-3 rounded-none relative mb-6 font-medium text-sm flex items-center gap-2 swiss-shadow-sm">
