          </div>
        </div>

        <!-- Discord Login History Section -->
        <div class="bg-white rounded-3xl p-6 sm:p-8 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-6 flex-wrap gap-4">
            <div>
