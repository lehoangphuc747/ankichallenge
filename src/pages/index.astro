---
import Layout from "../layouts/Layout.astro";
import ProgressBar from "../components/ProgressBar.astro";
---

<Layout title="Anki Challenge - Bảng xếp hạng">
	<main
		class="min-h-screen relative overflow-x-hidden selection:bg-cyan-500/30 text-slate-100"
	>
		<div class="fixed top-[-10%] left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-cyan-500/10 blur-[120px] rounded-full pointer-events-none z-0"></div>
		<div class="fixed bottom-[-10%] right-[-5%] w-[500px] h-[500px] bg-emerald-500/5 blur-[150px] rounded-full pointer-events-none z-0"></div>

		<div class="max-w-5xl mx-auto px-4 py-8 relative z-10 min-h-screen flex flex-col">
			<!-- Header Section (Compact) -->
			<div class="flex flex-col md:flex-row items-center justify-between mb-8 gap-6">
				<div class="flex flex-col items-center md:items-start gap-1">
					<h1 class="text-4xl md:text-5xl font-black tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white via-cyan-100 to-cyan-400 pb-1">
						Leaderboard
					</h1>
					<p class="text-cyan-400/80 font-bold tracking-widest uppercase text-xs mt-1" id="challengeTitle">
						100 ngày thử thách
					</p>
				</div>

				<div class="relative group w-full md:w-auto">
					<select
						id="challengeSelect"
						class="w-full md:w-auto appearance-none bg-white/5 border border-white/10 text-white text-sm font-semibold py-3 pl-5 pr-12 rounded-2xl focus:outline-none focus:ring-2 focus:ring-cyan-500/50 hover:bg-white/10 transition-all cursor-pointer backdrop-blur-md shadow-lg"
					>
						<option value="1" class="bg-zinc-900 text-white">Anki Challenge 8</option>
						<option value="2" class="bg-zinc-900 text-white">Anki Challenge 9</option>
						<option value="3" selected class="bg-zinc-900 text-white">Anki Challenge 10</option>
					</select>
					<div class="absolute right-4 top-1/2 transform -translate-y-1/2 pointer-events-none text-cyan-400">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
						</svg>
					</div>
				</div>
			</div>

			<!-- Progress Bar (Clean - Removed Inner Wrapper) -->
			<div
				class="mb-8"
			>
				<ProgressBar challengeId="3" />
			</div>

			<!-- Controls Bar -->
			<div class="sticky top-4 z-40 mb-6 bg-zinc-950/80 backdrop-blur-xl border border-white/10 rounded-2xl p-2 flex flex-col sm:flex-row gap-2 shadow-xl">
				<div class="relative flex-1 group">
					<!-- Search -->
					<div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-slate-500 group-focus-within:text-cyan-400 transition-colors">
						<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
							</svg>
						</div>
						<input
							type="text"
							id="searchInput"
							spellcheck="false"
							autocomplete="off"
							class="w-full pl-11 pr-8 py-2.5 bg-white/5 border border-transparent rounded-xl text-white placeholder-slate-500 focus:bg-white/10 focus:border-cyan-500/50 focus:outline-none transition-all text-sm font-medium"
							placeholder="Tìm kiếm thành viên..."
						/>
						<button id="clearSearch" class="absolute inset-y-0 right-0 pr-3 flex items-center opacity-0 pointer-events-none text-slate-500 hover:text-cyan-300 transition-all duration-300">
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
							</svg>
						</button>
				</div>

					<!-- Toggle Display Mode -->
					<div class="flex items-center gap-3 bg-black/50 px-4 py-2 rounded-xl border border-white/5 shrink-0">
						<span class="text-xs font-bold text-slate-400 uppercase tracking-wider hidden sm:inline-block">Hiển thị</span>
						<label for="displayModeToggle" class="relative inline-flex items-center cursor-pointer ml-auto sm:ml-0">
							<input type="checkbox" id="displayModeToggle" class="sr-only peer" />
							<div class="w-11 h-6 bg-zinc-800 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-cyan-500/50 rounded-full peer peer-checked:after:translate-x-5 peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-cyan-500"></div>
							<span class="ml-3 text-sm font-bold text-white w-20 text-center select-none" id="toggleLabel">Discord</span>
						</label>
					</div>
			</div>

			<!-- Loading State -->
			<div id="loading" class="text-center py-24">
				<div
					class="inline-flex items-center gap-4 px-8 py-5 rounded-3xl bg-[#0f172a] border-2 border-cyan-400/35"
				>
					<div class="relative w-7 h-7">
						<div
							class="absolute inset-0 rounded-full border-4 border-slate-700"
						>
						</div>
						<div
							class="absolute inset-0 rounded-full border-4 border-cyan-300 border-t-transparent animate-spin"
						>
						</div>
					</div>
					<span class="text-lg font-bold text-cyan-100"
						>Đang tải dữ liệu...</span
					>
				</div>
			</div>

			<!-- Board Content -->
			<div
				id="leaderboard"
				class="hidden animate-fade-in-up group show-discord"
			>
				<!-- Mobile Cards -->
				<div class="md:hidden space-y-4" id="leaderboardCards">
					<div id="leaderboardCardsBody" class="space-y-4"></div>
				</div>

				<!-- Desktop Cards -->
				<div class="hidden md:block space-y-3" id="leaderboardDesktopBody">
					<!-- Desktop cards injected here -->
				</div>
			</div>

			<div class="mt-12 text-center pb-8 opacity-60 hover:opacity-100 transition-opacity">
				<p
					class="inline-flex items-center px-5 py-2.5 rounded-full bg-white/5 border border-white/10 text-slate-400 text-xs font-bold uppercase tracking-widest backdrop-blur-sm"
					id="dataInfo"
				>
					<span
						class="w-2 h-2 rounded-full bg-emerald-400 mr-2.5 animate-pulse shadow-[0_0_8px_rgba(52,211,153,0.8)]"
					></span>
					Cập nhật: <span
						id="lastUpdateStr"
						class="ml-1.5 text-white">--</span
					>
					<span class="mx-3 text-white/20">|</span>
					<span id="memberCountSummary" class="text-white"
						>-- thành viên</span
					>
				</p>
			</div>
		</div>
	</main>
</Layout>

<style>
	@import url("https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800;900&display=swap");

	:global(*) {
		font-family: "Space Grotesk", sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	:global(body) {
		background-color: #09090b;
		color: #e2e8f0;
		margin: 0;
		min-height: 100vh;
	}

	@keyframes fade-in-up {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in-up {
		animation: fade-in-up 0.6s ease-out forwards;
	}

	::-webkit-scrollbar {
		width: 8px;
		height: 8px;
	}

	::-webkit-scrollbar-track {
		background: #09090b;
	}

	::-webkit-scrollbar-thumb {
		background: #27272a;
		border-radius: 4px;
	}

	::-webkit-scrollbar-thumb:hover {
		background: #3f3f46;
	}

	.no-scrollbar::-webkit-scrollbar {
		display: none;
	}

	.no-scrollbar {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>

<script>
	import { calculateUserStats } from "../utils/calculateStats.js";

	let currentChallengeId = "3";
	let currentSearchQuery = "";
	type LeaderboardUser = {
		id: number;
		name?: string;
		discordNickname?: string;
		hidden?: boolean;
		role?: string;
		challengeIds?: number[];
	};
	type LeaderboardMember = LeaderboardUser & {
		streak: number;
		longestStreak: number;
		totalDays: number;
		disciplinePercentage: number;
		rank?: number;
	};
	type UsersPayload = { data?: LeaderboardUser[] };
	type ChallengeMeta = { name?: string };
	type ChallengesConfig = Record<string, ChallengeMeta>;
	type SearchTimer = ReturnType<typeof setTimeout>;
	let allMembersWithStats: LeaderboardMember[] = [];
	// Default to Discord, toggle checked state implies "Name" if unchecked or checked?
	// Let's say CHECKED = Name (On), UNCHECKED = Discord (Off) or vice versa.
	// User said "Switch Name and Discord".
	// Let's implement: OFF (Left) = Discord, ON (Right) = Name.
	let displayMode =
		localStorage.getItem("leaderboardDisplayMode") || "discord";

	let challengesConfig: ChallengesConfig = {};
	let studyRecordsData: unknown = null;
	let usersData: UsersPayload | null = null;
	const leaderboardWindow = window as Window & {
		updateProgressBar?: (challengeId: string) => void;
	};

	async function loadStaticData(challengeId = "3") {
		try {
			const metadataResponse = await fetch(
				"/data/metadata.json?v=" + Date.now(),
			);
			const metadata = await metadataResponse.json();
			const cacheBuster = metadata?.lastUpdated
				? "?v=" + new Date(metadata.lastUpdated).getTime()
				: "?v=" + Date.now();

			const lastUpdateStr = document.getElementById("lastUpdateStr");
			if (lastUpdateStr && metadata?.lastUpdated) {
				const date = new Date(metadata.lastUpdated);
				lastUpdateStr.textContent = date.toLocaleString("vi-VN", {
					hour: "2-digit",
					minute: "2-digit",
					day: "2-digit",
					month: "2-digit",
				});
			}

			let prefix = '08';
			if (challengeId === "1") prefix = '08';
			if (challengeId === "2") prefix = '09';
			if (challengeId === "3") prefix = '10';

			const [studyRecordsResponse, usersResponse, challengesResponse] = await Promise.all([
				fetch(`/data/challenge_${prefix}_records.json` + cacheBuster),
				fetch("/data/users.json" + cacheBuster),
				fetch("/data/challenges.json" + cacheBuster)
			]);

			studyRecordsData = await studyRecordsResponse.json();
			usersData = await usersResponse.json();
			challengesConfig = await challengesResponse.json();
		} catch (error) {
			console.error("Error loading static data:", error);
			throw error;
		}
	}

	function calculateUserStatsForLeaderboard(userId: number, challengeId: string) {
		try {
			if (!studyRecordsData || !usersData)
				return {
					streak: 0,
					longestStreak: 0,
					totalDays: 0,
					disciplinePercentage: 0,
				};

			const users = usersData.data || [];
			const user = users.find((u: LeaderboardUser) => u.id === userId);

			if (!user)
				return {
					streak: 0,
					longestStreak: 0,
					totalDays: 0,
					disciplinePercentage: 0,
				};

			const usersWithStats = calculateUserStats(
				[user],
				studyRecordsData,
				challengeId,
				challengesConfig,
			);

			if (usersWithStats.length === 0 || !usersWithStats[0].currentStat) {
				return {
					streak: 0,
					longestStreak: 0,
					totalDays: 0,
					disciplinePercentage: 0,
				};
			}

			const stat = usersWithStats[0].currentStat;

			return {
				streak: stat.streak,
				longestStreak: stat.longestStreak,
				totalDays: stat.totalDays,
				disciplinePercentage: stat.disciplinePercentage,
			};
		} catch (error) {
			console.error("[LEADERBOARD] Error calculating stats:", error);
			return {
				streak: 0,
				longestStreak: 0,
				totalDays: 0,
				disciplinePercentage: 0,
			};
		}
	}

	// --- OPTIMIZED RENDER LOGIC WITH CSS TOGGLE ---
	function getDisplayNameHTML(member: LeaderboardMember) {
		const name = member.name || "Không có tên";
		const discord = member.discordNickname || name;
		// Render both, toggle visibility via CSS
		// Default show-discord is set on parent.
		// If .show-name on parent -> .name-display: block, .discord-display: hidden
		return `
			<span class="name-display hidden group-[.show-name]:inline text-ellipsis overflow-hidden whitespace-nowrap text-slate-100 font-bold">${name}</span>
			<span class="discord-display hidden group-[.show-discord]:inline text-ellipsis overflow-hidden whitespace-nowrap text-cyan-300 font-bold font-mono text-sm">${discord}</span>
		`;
	}

	function getMobileDisplayNameHTML(member: LeaderboardMember) {
		const name = member.name || "Không có tên";
		const discord = member.discordNickname || name;
		return `
			<span class="name-display hidden group-[.show-name]:inline text-ellipsis overflow-hidden whitespace-nowrap text-slate-100 font-bold">${name}</span>
			<span class="discord-display hidden group-[.show-discord]:inline text-ellipsis overflow-hidden whitespace-nowrap text-cyan-300 font-bold font-mono text-sm">${discord}</span>
		`;
	}

	function updateMemberCount(challengeId: string) {
		try {
			if (!usersData || !usersData.data) {
				const progressMemberCountEl = document.getElementById("progressMemberCount");
				const summaryMemberCountEl = document.getElementById("memberCountSummary");
				if (progressMemberCountEl) progressMemberCountEl.textContent = "-- thành viên";
				if (summaryMemberCountEl) summaryMemberCountEl.textContent = "-- thành viên";
				return;
			}
			const members = usersData.data || [];
			const challengeIdNum = parseInt(challengeId);
			const challengeMembers = members.filter(
				(m) =>
					!m.hidden &&
					m.challengeIds &&
					m.challengeIds.includes(challengeIdNum),
			);

			const memberCountText = `${challengeMembers.length} thành viên`;
			const progressMemberCountEl = document.getElementById("progressMemberCount");
			const summaryMemberCountEl = document.getElementById("memberCountSummary");
			if (progressMemberCountEl) progressMemberCountEl.textContent = memberCountText;
			if (summaryMemberCountEl) summaryMemberCountEl.textContent = memberCountText;
		} catch (error) {
			console.error("Error updating member count:", error);
		}
	}

	function updateDisplayModeConfig() {
		const toggle = document.getElementById("displayModeToggle") as HTMLInputElement | null;
		const label = document.getElementById("toggleLabel");
		const leaderboard = document.getElementById("leaderboard");

		if (toggle) {
			// If mode is 'name', toggle should be CHECKED (ON)
			toggle.checked = displayMode === "name";
		}

		if (label) {
			label.textContent = displayMode === "name" ? "Tên thật" : "Discord";
			label.className =
				displayMode === "name"
					? "ml-3 text-sm font-bold text-cyan-100 w-20 text-center select-none transition-colors"
					: "ml-3 text-sm font-bold text-cyan-100/55 w-20 text-center select-none transition-colors";
		}

		// Update CSS classes
		if (leaderboard) {
			leaderboard.classList.remove("show-name", "show-discord");
			if (displayMode === "name") {
				leaderboard.classList.add("show-name");
			} else {
				leaderboard.classList.add("show-discord");
			}
		}
	}

	async function loadLeaderboard(challengeId: string) {
		try {
			const loadingDiv = document.getElementById("loading");
			const leaderboardDiv = document.getElementById("leaderboard");
			const leaderboardDesktopBody = document.getElementById("leaderboardDesktopBody");
			const leaderboardCardsBody = document.getElementById(
				"leaderboardCardsBody",
			);

			if (loadingDiv) loadingDiv.classList.remove("hidden");
			if (leaderboardDiv) leaderboardDiv.classList.add("hidden");

			if (!usersData || !studyRecordsData) await loadStaticData(challengeId);

			if (!usersData || !usersData.data) {
				if (loadingDiv)
					loadingDiv.innerHTML =
						'<p class="text-red-500">Không tìm thấy dữ liệu</p>';
				return;
			}

			const members = usersData.data || [];
			const challengeIdNum = parseInt(challengeId);
			const challengeMembers = members.filter(
				(m: LeaderboardUser) =>
					!m.hidden &&
					m.challengeIds &&
					m.challengeIds.includes(challengeIdNum),
			);

			updateMemberCount(challengeId);

			const membersWithStats: LeaderboardMember[] = challengeMembers.map((member: LeaderboardUser) => {
				const stats = calculateUserStatsForLeaderboard(
					member.id,
					challengeId,
				);
				return { ...member, ...stats };
			});

			membersWithStats.sort(
				(a, b) => b.disciplinePercentage - a.disciplinePercentage,
			);
			allMembersWithStats = membersWithStats;

			const filteredMembers = applySearchFilter(
				membersWithStats,
				currentSearchQuery,
			);

			if (loadingDiv) loadingDiv.classList.add("hidden");
			if (leaderboardDiv) leaderboardDiv.classList.remove("hidden");

			// Apply display mode classes immediately
			updateDisplayModeConfig();

			if (!leaderboardDesktopBody && !leaderboardCardsBody) return;

			if (filteredMembers.length === 0) {
				const emptyMessage = currentSearchQuery
					? `Không tìm thấy thành viên nào với từ khóa "${currentSearchQuery}"`
					: "Chưa có thành viên nào trong challenge này";
				if (leaderboardDesktopBody)
					leaderboardDesktopBody.innerHTML = `<div class="text-center text-slate-500 py-8 text-base bg-white/[0.02] border border-white/10 rounded-2xl">${emptyMessage}</div>`;
				if (leaderboardCardsBody)
					leaderboardCardsBody.innerHTML = `<div class="text-center text-slate-500 py-8 text-base">${emptyMessage}</div>`;
				return;
			}

			let currentRank = 1;
			allMembersWithStats.forEach((member: LeaderboardMember, index: number) => {
				if (
					index > 0 &&
					member.disciplinePercentage <
						allMembersWithStats[index - 1].disciplinePercentage
				) {
					currentRank = index + 1;
				}
				member.rank = currentRank;
			});

			// --- Challenge 10 style rendering helpers ---

			function getRankBadge(rank: number) {
				return String(rank || 0);
			}

			function getRankCircleClass(rank: number) {
				if (rank === 1)
					return "bg-[rgba(251,191,36,0.12)] border-[rgba(251,191,36,0.65)] text-[#facc15]";
				if (rank === 2)
					return "bg-[rgba(148,163,184,0.18)] border-[rgba(203,213,225,0.55)] text-[#cbd5e1]";
				if (rank === 3)
					return "bg-[rgba(34,211,238,0.12)] border-[rgba(34,211,238,0.55)] text-[#67e8f9]";
				return "bg-black/35 border-white/10 text-slate-400";
			}

			function getDesktopCardClass(rank: number) {
				if (rank === 1)
					return "border-[rgba(251,191,36,0.72)] bg-[linear-gradient(100deg,rgba(251,191,36,0.17)_0%,rgba(6,15,24,0.96)_40%,rgba(10,30,24,0.94)_100%)]";
				if (rank === 2)
					return "border-[rgba(148,163,184,0.62)] bg-[linear-gradient(100deg,rgba(148,163,184,0.12)_0%,rgba(8,13,22,0.97)_42%,rgba(11,22,24,0.95)_100%)]";
				return "border-white/8 bg-[linear-gradient(100deg,rgba(2,6,16,0.95)_0%,rgba(2,10,22,0.95)_50%,rgba(4,20,20,0.92)_100%)]";
			}

			function getTopRowClass(_rank: number) {
				return "";
			}

			function getTotalDaysHighlightClass(totalDays: number) {
				const tier = Math.floor(totalDays / 10);
				const colorTiers = [
					{ bg: "", border: "" },
					{ bg: "bg-cyan-400/5", border: "border-l-[3px] border-cyan-300/45" },
					{ bg: "bg-cyan-400/6", border: "border-l-[3px] border-cyan-300/45" },
					{ bg: "bg-emerald-400/5", border: "border-l-[3px] border-emerald-300/45" },
					{ bg: "bg-green-400/5", border: "border-l-[3px] border-green-400/45" },
					{ bg: "bg-green-400/5", border: "border-l-[3px] border-green-400/45" },
					{ bg: "bg-[rgba(255,217,102,0.08)]", border: "border-l-[3px] border-[#ffd966]" },
					{ bg: "bg-[rgba(255,217,102,0.1)]", border: "border-l-[3px] border-[#ffd966]" },
					{ bg: "bg-[rgba(255,212,216,0.08)]", border: "border-l-[3px] border-[#ffd4d8]" },
					{ bg: "bg-[rgba(255,212,216,0.1)]", border: "border-l-[3px] border-[#ffd4d8]" },
				];
				if (tier >= 10)
					return {
						bg: "bg-[rgba(0,255,148,0.08)]",
						border: "border-l-[4px] border-[#00ff94]",
					};
				return colorTiers[tier] || { bg: "", border: "" };
			}

			// Render Desktop Blocks
			if (leaderboardDesktopBody) {
				leaderboardDesktopBody.innerHTML = filteredMembers
					.map((member: LeaderboardMember) => {
						const memberRank = member.rank ?? 0;
						const rankBadge = getRankBadge(memberRank);
						const topCardClass = getTopRowClass(memberRank);
						const baseCardClass = getDesktopCardClass(memberRank);
						const cardClass = topCardClass || baseCardClass;

						let disciplineColor = "text-cyan-300";
						let barColor = "bg-cyan-300";
						if (memberRank === 1) {
							disciplineColor = "text-[#facc15]";
							barColor = "bg-[#facc15]";
						} else if (member.disciplinePercentage < 50) {
							disciplineColor = "text-rose-400";
							barColor = "bg-rose-500";
						}

						const rankCircleClass = getRankCircleClass(memberRank);

						return `
						<a href="/profile/${member.id}" target="_blank" class="relative block rounded-[22px] px-6 py-5 ${cardClass} transition-all duration-200 hover:border-cyan-300/35 overflow-hidden border">
							<div class="flex items-center gap-5">
								<div class="flex items-center justify-center w-12 h-12 rounded-full border text-2xl leading-none font-black shrink-0 ${rankCircleClass}">${rankBadge}</div>
								<div class="min-w-0 w-[21rem] lg:w-[24rem]">
									<div class="flex items-center gap-2 overflow-hidden">
										<div class="font-bold text-2xl leading-tight text-slate-100 truncate">${displayMode === "name" ? (member.name || "Không có tên") : (member.discordNickname || member.name || "Không có tên")}</div>
										${member.role === "admin" ? '<span class="px-2 py-0.5 rounded-md text-[10px] font-black uppercase tracking-wide bg-cyan-500/25 text-cyan-300 border border-cyan-400/35 shrink-0">Admin</span>' : ""}
									</div>
									<div class="text-sm text-slate-400 font-medium mt-1.5 tracking-wide">ID: ${member.id} <span class="mx-1.5">•</span> ${member.discordNickname || "--"}</div>
								</div>
								<div class="flex-1 grid grid-cols-4 gap-5 items-center">
									<div class="text-center">
										<div class="text-xs text-slate-500 uppercase font-bold mb-1 tracking-widest">Chuỗi</div>
										<div class="text-4xl font-black ${memberRank === 1 ? "text-[#facc15]" : "text-cyan-300"} leading-none tabular-nums">${member.streak}</div>
									</div>
									<div class="text-center">
										<div class="text-xs text-slate-500 uppercase font-bold mb-1 tracking-widest">Kỷ lục</div>
										<div class="text-3xl font-bold text-slate-300 leading-none tabular-nums">${member.longestStreak}</div>
									</div>
									<div class="text-center">
										<div class="text-xs text-slate-500 uppercase font-bold mb-1 tracking-widest">Tổng ngày</div>
										<div class="text-3xl font-bold text-slate-300 leading-none tabular-nums">${member.totalDays}</div>
									</div>
									<div class="text-right pr-2">
										<div class="text-xs text-slate-500 uppercase font-bold mb-1 tracking-widest">Kỷ luật</div>
										<div class="text-3xl leading-none font-black ${disciplineColor} tabular-nums mb-2">${member.disciplinePercentage}%</div>
										<div class="w-28 h-2 bg-black/55 rounded-full overflow-hidden ml-auto">
											<div class="h-full ${barColor}" style="width: ${member.disciplinePercentage}%"></div>
										</div>
									</div>
								</div>
							</div>
						</a>
					`;
					})
					.join("");
			}

			if (leaderboardCardsBody) {
				leaderboardCardsBody.innerHTML = filteredMembers
					.map((member: LeaderboardMember) => {
						const memberRank = member.rank ?? 0;
						const rankBadge = getRankBadge(memberRank);
						const cardClass = getDesktopCardClass(memberRank);
						const rankCircleClass = getRankCircleClass(memberRank);

						let disciplineColor = "text-cyan-300";
						let barColor = "bg-cyan-300";
						if (memberRank === 1) {
							disciplineColor = "text-[#facc15]";
							barColor = "bg-[#facc15]";
						} else if (member.disciplinePercentage < 50) {
							disciplineColor = "text-rose-400";
							barColor = "bg-rose-500";
						}

						return `
						<a
							href="/profile/${member.id}"
							target="_blank"
							class="block rounded-2xl p-4 border ${cardClass} active:scale-[0.98] transition-all"
						>
							<div class="flex items-start justify-between gap-3 max-w-full">
								<div class="flex items-center gap-3 min-w-0">
									<div class="flex items-center justify-center w-11 h-11 rounded-full border text-xl leading-none font-black shrink-0 ${rankCircleClass}">
										${rankBadge}
									</div>
									<div class="min-w-0">
										<div class="font-bold text-lg text-slate-100 leading-tight flex items-center gap-1.5 overflow-hidden">
											${displayMode === "name" ? (member.name || "Không có tên") : (member.discordNickname || member.name || "Không có tên")}
											${member.role === "admin" ? '<span class="text-[9px] uppercase font-black bg-cyan-500/20 text-cyan-300 px-1 py-0.5 rounded shrink-0 border border-cyan-500/30">Admin</span>' : ""}
										</div>
										<div class="text-xs text-slate-400 mt-0.5">ID: ${member.id} <span class="mx-1">•</span> ${member.discordNickname || "--"}</div>
									</div>
								</div>
								<div class="text-right shrink-0">
									<div class="text-3xl font-black ${memberRank === 1 ? "text-[#facc15]" : "text-cyan-300"} tabular-nums leading-none">${member.streak}</div>
									<div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold mt-1">Chuỗi</div>
								</div>
							</div>

							<div class="grid grid-cols-3 gap-2 py-2.5 border-t border-white/10 mt-3">
								<div class="text-center">
									<div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold mb-0.5">Kỷ lục</div>
									<div class="font-bold text-slate-300 tabular-nums text-xl leading-none">${member.longestStreak}</div>
								</div>
								<div class="text-center border-l border-white/10">
									<div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold mb-0.5">Tổng ngày</div>
									<div class="font-bold text-slate-100 tabular-nums text-xl leading-none">${member.totalDays}</div>
								</div>
								<div class="text-center border-l border-white/10">
									<div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold mb-0.5">Kỷ luật</div>
									<div class="font-black ${disciplineColor} tabular-nums text-xl leading-none">${member.disciplinePercentage}%</div>
								</div>
							</div>

							<div class="mt-1.5 w-full h-2 bg-black/55 rounded-full overflow-hidden">
								<div class="h-full ${barColor}" style="width: ${member.disciplinePercentage}%"></div>
							</div>
						</a>
					`;
					})
					.join("");
			}
		} catch (error: unknown) {
			console.error("Error loading leaderboard:", error);
			const loadingDiv = document.getElementById("loading");
			if (loadingDiv) {
				const errorMessage = error instanceof Error ? error.message : String(error);
				loadingDiv.innerHTML = `<p class="text-red-500">Lỗi: ${errorMessage}</p>`;
			}
		}
	}

	function applySearchFilter(members: LeaderboardMember[], searchQuery: string) {
		if (!searchQuery || searchQuery.trim() === "") return members;
		const query = searchQuery.trim().toLowerCase();
		return members.filter((member: LeaderboardMember) => {
			const id = String(member.id || "").toLowerCase();
			const name = (member.name || "").toLowerCase();
			const discord = (member.discordNickname || "").toLowerCase();
			return (
				id.includes(query) ||
				name.includes(query) ||
				discord.includes(query)
			);
		});
	}

	function renderFilteredLeaderboard() {
		loadLeaderboard(currentChallengeId);
	}

	const challengeSelect = document.getElementById("challengeSelect") as HTMLSelectElement | null;
	if (challengeSelect) {
		challengeSelect.addEventListener("change", async (e) => {
			const target = e.currentTarget as HTMLSelectElement | null;
			if (!target) return;
			currentChallengeId = target.value;
			currentSearchQuery = "";
			const searchInput = document.getElementById("searchInput") as HTMLInputElement | null;
			if (searchInput) searchInput.value = "";
			const clearSearchBtn = document.getElementById("clearSearch") as HTMLButtonElement | null;
			if (clearSearchBtn) {
				clearSearchBtn.classList.remove("opacity-100");
				clearSearchBtn.classList.add("opacity-0", "pointer-events-none");
			}
			leaderboardWindow.updateProgressBar?.(currentChallengeId);
			const titleEl = document.getElementById("challengeTitle");
			// Update title logic...
			if (titleEl) {
				const challengeName = challengesConfig[currentChallengeId]?.name || `Challenge ${currentChallengeId}`;
				titleEl.textContent = `${challengeName} - 100 ngày thử thách`;
			}
			
			await loadStaticData(currentChallengeId);
			updateMemberCount(currentChallengeId);
			loadLeaderboard(currentChallengeId);
		});
	}

	const searchInput = document.getElementById("searchInput") as HTMLInputElement | null;
	const clearSearchBtn = document.getElementById("clearSearch") as HTMLButtonElement | null;
	if (searchInput) {
		let searchTimeout: SearchTimer | undefined;
		searchInput.addEventListener("input", (e) => {
			clearTimeout(searchTimeout);
			const target = e.currentTarget as HTMLInputElement | null;
			currentSearchQuery = target?.value || "";
			if (clearSearchBtn) {
				if (currentSearchQuery.trim() !== "") {
					clearSearchBtn.classList.remove("opacity-0", "pointer-events-none");
					clearSearchBtn.classList.add("opacity-100");
				} else {
					clearSearchBtn.classList.remove("opacity-100");
					clearSearchBtn.classList.add("opacity-0", "pointer-events-none");
				}
			}
			searchTimeout = setTimeout(() => {
				renderFilteredLeaderboard();
			}, 300);
		});
	}

	if (clearSearchBtn) {
		clearSearchBtn.addEventListener("click", () => {
			currentSearchQuery = "";
			if (searchInput) {
				searchInput.value = "";
				searchInput.focus();
			}
			clearSearchBtn.classList.remove("opacity-100");
			clearSearchBtn.classList.add("opacity-0", "pointer-events-none");
			renderFilteredLeaderboard();
		});
	}

	const displayModeToggle = document.getElementById("displayModeToggle") as HTMLInputElement | null;

	function switchDisplayMode(isNameMode: boolean) {
		displayMode = isNameMode ? "name" : "discord";
		localStorage.setItem("leaderboardDisplayMode", displayMode);
		updateDisplayModeConfig();
		renderFilteredLeaderboard();
	}

	if (displayModeToggle) {
		displayModeToggle.addEventListener("change", (e) => {
			const target = e.currentTarget as HTMLInputElement | null;
			switchDisplayMode(Boolean(target?.checked));
		});
	}

	// Initial styling (without waiting for JS)
	updateDisplayModeConfig();

	if ("requestIdleCallback" in window) {
		requestIdleCallback(
			async () => {
				await loadStaticData(currentChallengeId);
				updateMemberCount(currentChallengeId);
				loadLeaderboard(currentChallengeId);
			},
			{ timeout: 1000 },
		);
	} else {
		setTimeout(async () => {
			await loadStaticData(currentChallengeId);
			updateMemberCount(currentChallengeId);
			loadLeaderboard(currentChallengeId);
		}, 0);
	}
</script>
