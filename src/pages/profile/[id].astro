        </button>
      `;
    }).join('');

    selectorEl.innerHTML = html;

    // Add click handlers
    document.querySelectorAll('.challenge-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const challengeId = parseInt(btn.getAttribute('data-challenge-id'));
        switchChallenge(challengeId);
