---
import Layout from '../../layouts/Layout.astro';
import CertificateCardStyles from '../../components/CertificateCardStyles.astro';

// Import dữ liệu người dùng để Astro biết trước danh sách `id` khi build static
import usersData from '../../../public/data/users.json';

// Astro yêu cầu dynamic route phải khai báo getStaticPaths() để build tĩnh
export function getStaticPaths() {
  const members = (usersData && usersData.data) ? usersData.data : [];
  
  // Trả về danh sách đường dẫn: /profile/9, /profile/10, ...
  return members.map((member: any) => ({
    params: { id: String(member.id) }
  }));
}
---

<Layout title="Chi tiết thành viên">
  <main class="profile-shell min-h-screen bg-[#09090b] text-slate-100 flex flex-col md:flex-row relative">
    <div class="absolute top-[-8%] left-1/2 -translate-x-1/2 w-[900px] h-[420px] bg-cyan-500/10 blur-[130px] rounded-full pointer-events-none z-0"></div>
    <div class="absolute bottom-[-10%] right-[-8%] w-[520px] h-[520px] bg-emerald-500/5 blur-[150px] rounded-full pointer-events-none z-0"></div>
    
    <!-- Sidebar Overlay (Mobile) -->
    <div 
      id="sidebarOverlay" 
      class="fixed inset-0 bg-slate-950/70 backdrop-blur-sm z-40 hidden md:hidden transition-opacity"
    ></div>

    <!-- Sidebar -->
    <aside 
      id="profileSidebar" 
      class="fixed left-0 top-0 bottom-0 w-80 max-w-[86vw] z-40 transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out overflow-y-auto border-r border-white/5"
    >
      <div class="p-5 sticky top-0 bg-[#05070c]/95 border-b border-white/10 z-10 backdrop-blur-xl">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-[2rem] leading-none font-bold tracking-tight text-slate-100">Thành viên</h2>
          <button 
            id="sidebarClose" 
            class="md:hidden p-2 rounded-xl bg-white/5 text-slate-300 hover:bg-white/10 transition-colors"
            aria-label="Close sidebar"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        <!-- Challenge Filter -->
        <div class="mb-3">
          <select 
            id="sidebarChallengeFilter" 
            class="sidebar-control sidebar-select"
          >
            <option value="all">Tất cả</option>
            <option value="1">Anki Challenge 8</option>
            <option value="2">Anki Challenge 9</option>
            <option value="3">Anki Challenge 10</option>
          </select>
        </div>
        <!-- Search Input -->
        <div class="sidebar-search-wrap">
          <svg class="sidebar-search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <input 
            type="text" 
            id="sidebarSearch" 
            placeholder="Tìm kiếm..." 
            class="sidebar-control sidebar-search"
          />
        </div>
      </div>
      <div id="sidebarUserList" class="p-2.5 space-y-2.5">
        <!-- User list will be populated by JavaScript -->
        <div class="text-center py-8 text-slate-400">Đang tải...</div>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="relative z-10 w-full md:w-[calc(100%-20rem)] md:ml-80 transition-all duration-300 min-h-screen py-6 md:py-8 px-4">
      <div class="max-w-5xl mx-auto w-full md:px-6">
      <!-- Top Bar with Toggle and Back Button (Mobile) -->
      <div class="mb-6 flex items-center gap-3 md:block">
        <!-- Sidebar Toggle Button (Mobile) -->
        <button 
          id="sidebarToggle" 
          class="profile-action p-3 rounded-xl md:hidden flex-shrink-0"
          aria-label="Toggle sidebar"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
        <!-- Back Button -->
        <a href="/" class="profile-action inline-flex items-center justify-center gap-2 flex-1 md:flex-none">
          ← Quay lại BXH
        </a>
      </div>

      <div id="loading" class="text-center py-12">
        <div class="aurora-card inline-block px-8 py-6 rounded-[28px]">
          <p class="text-xl font-bold text-slate-100">Đang tải dữ liệu...</p>
        </div>
      </div>

      <!-- Profile Content -->
      <div id="profileContent" class="hidden space-y-6">
        <!-- Header Card -->
        <div class="aurora-card profile-hero-card rounded-3xl p-6 md:p-10 relative overflow-hidden">
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
          <div class="text-center">
            <h1 class="text-4xl md:text-5xl font-black text-slate-100 mb-2" id="userName"></h1>
            <p class="text-sm md:text-base text-slate-400 mb-4 max-w-3xl mx-auto leading-relaxed" id="userBio"></p>
            <div class="flex gap-3 justify-center flex-wrap" id="userMeta"></div>
          </div>
        </div>

        <!-- Challenge Selector -->
        <div id="challengeSelector" class="flex gap-3 flex-wrap justify-center mb-6">
          <!-- Will be populated by JavaScript -->
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4" id="statsGrid">
        </div>

        <!-- Certificates Section -->
        <div class="aurora-card profile-section-card rounded-3xl p-6 md:p-8" id="certificatesSection">
          <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3 mb-6 sm:mb-8">
            <h2 class="flex items-center gap-3 text-2xl sm:text-3xl font-bold text-slate-100 m-0">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-yellow-400/10 text-yellow-300 border border-yellow-300/25">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="8" r="6"></circle>
                  <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"></path>
                </svg>
              </span>
              Chứng chỉ & Thành tích
            </h2>
            <div class="h-px bg-white/10 w-full sm:flex-1 rounded-full hidden sm:block"></div>
          </div>
          <div id="certificatesList" class="cert-grid">
            <!-- Certificates will be rendered here by JavaScript -->
          </div>
          <div id="noCertificates" class="hidden text-center py-8 text-slate-400">
            Chưa có chứng chỉ nào. Hãy hoàn thành các thử thách để nhận chứng chỉ.
          </div>
        </div>

        <!-- Calendar History -->
        <div class="aurora-card profile-section-card rounded-3xl p-6 md:p-8">
          <h2 class="text-2xl font-bold text-slate-100 mb-6">Lịch sử Check-in</h2>
          <div id="calendar" class="space-y-8">
          </div>
        </div>

        <!-- Detailed History -->
        <div class="aurora-card profile-section-card rounded-3xl p-6 md:p-8">
          <h2 class="text-2xl font-bold text-slate-100 mb-6">Chi tiết theo tháng</h2>
          <div id="monthlyStats"></div>
        </div>
      </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { calculateUserStats } from '../../utils/calculateStats.js';

  // Lấy userId từ URL nhưng chống lỗi dấu "/" ở cuối (Cloudflare thường redirect thành /profile/9/)
  const pathParts = window.location.pathname.split('/').filter(Boolean);
  const userId = pathParts[pathParts.length - 1];

  let challengesConfig = {};
  let challengeDateRanges = {};
  let challengeNames = {};

  async function loadProfile() {
    try {
      const loadingDiv = document.getElementById('loading');
      const profileContent = document.getElementById('profileContent');

      // Load user data and study records (thêm cache-busting để CDN không cache data cũ)
      const cacheBuster = '?v=' + Date.now();
      const [usersResponse, challengesResponse] = await Promise.all([
        fetch('/data/users.json' + cacheBuster),
        fetch('/data/challenges.json' + cacheBuster)
      ]);
      const usersData = await usersResponse.json();
      challengesConfig = await challengesResponse.json();

      // Determine date ranges and names dynamically
      challengeDateRanges = Object.fromEntries(
        Object.entries(challengesConfig).map(([id, config]) => [
          id, 
          { start: config.start, end: config.certEnd || config.end }
        ])
      );

      challengeNames = Object.fromEntries(
        Object.entries(challengesConfig).map(([id, config]) => [id, config.name])
      );

      
      console.log('📦 [PROFILE] usersData:', usersData ? 'EXISTS' : 'NULL');
      
      if (!usersData || !usersData.data) {
        if (loadingDiv) loadingDiv.innerHTML = '<p class="text-red-500">Dữ liệu người dùng không hợp lệ</p>';
        console.error('❌ [PROFILE] usersData or usersData.data is null/undefined');
        return;
      }
      
      const members = usersData.data || [];
      console.log('👥 [PROFILE] Found', members.length, 'members');
      
      // Store all users for sidebar
      allUsers = members;
      
      const user = members.find(m => m.id.toString() === userId);

      if (!user) {
        if (loadingDiv) loadingDiv.innerHTML = '<p class="text-red-500">Không tìm thấy thành viên</p>';
        return;
      }

      const userChallengeIds = user.challengeIds || ['1'];
      // Fetch only the relevant challenge records
      const recordsArray = await Promise.all(userChallengeIds.map(async (cid) => {
        let prefix = '08';
        if (cid == 1) prefix = '08';
        if (cid == 2) prefix = '09';
        if (cid == 3) prefix = '10';
        try {
          const res = await fetch(`/data/challenge_${prefix}_records.json` + cacheBuster);
          if (res.ok) return await res.json();
        } catch (e) {}
        return {};
      }));

      const allRecords = {};
      recordsArray.forEach(records => {
        Object.keys(records).forEach(date => {
          if (!allRecords[date]) allRecords[date] = {};
          Object.assign(allRecords[date], records[date]);
        });
      });

      console.log('📚 [PROFILE] Study records loaded:', Object.keys(allRecords).length, 'dates');

      // Get user's challenges
      const challengeIds = user.challengeIds || ['1'];

      console.log('🎯 [PROFILE] Calculating stats for user:', user.name, 'ID:', userId);
      console.log('🎯 [PROFILE] Challenges:', challengeIds);

      // Calculate stats for each challenge using shared utility
      const challengeStats = [];
      console.log('🔄 [PROFILE] Starting to process', challengeIds.length, 'challenges');
      
      for (const challengeId of challengeIds) {
        console.log(`\n📊 [PROFILE] Processing Challenge ${challengeId}...`);
        
        // Use the shared calculateUserStats function
        const usersWithStats = calculateUserStats([user], allRecords, challengeId, challengeDateRanges);
        console.log('📊 [PROFILE] calculateUserStats returned:', usersWithStats.length, 'results');
        
        if (usersWithStats.length > 0 && usersWithStats[0].currentStat) {
          const stat = usersWithStats[0].currentStat;
          challengeStats.push({
            challengeId: parseInt(challengeId),
            dates: stat.dates,
            streak: stat.streak,
            longestStreak: stat.longestStreak,
            totalDays: stat.totalDays,
            disciplinePercentage: stat.disciplinePercentage
          });
          
          console.log(`✅ [PROFILE] Challenge ${challengeId} stats:`, {
            streak: stat.streak,
            longestStreak: stat.longestStreak,
            totalDays: stat.totalDays,
            discipline: stat.disciplinePercentage + '%',
            datesCount: stat.dates?.length || 0
          });
        } else {
          console.warn(`⚠️ [PROFILE] No stats returned for Challenge ${challengeId}`);
        }
      }
      
      console.log('✅ [PROFILE] Total challenges with stats:', challengeStats.length);

      // Display profile
      displayProfile(user, challengeStats, allRecords);

      // Determine default challenge filter (use latest challenge from user's challengeIds, or 'all')
      let defaultChallengeId = 'all';
      if (challengeIds.length > 0) {
        // Use the latest challenge (highest ID) or first challenge
        const sortedChallengeIds = [...challengeIds].map(id => parseInt(id)).sort((a, b) => b - a);
        defaultChallengeId = sortedChallengeIds[0].toString();
      }
      currentSidebarChallengeFilter = defaultChallengeId;

      // Update challenge filter dropdown
      setTimeout(() => {
        const challengeFilterEl = document.getElementById('sidebarChallengeFilter');
        if (challengeFilterEl) {
          challengeFilterEl.value = defaultChallengeId;
        }
      }, 100);

      // Load and render sidebar
      renderSidebar(userId, defaultChallengeId);

      if (loadingDiv) loadingDiv.classList.add('hidden');
      if (profileContent) profileContent.classList.remove('hidden');

    } catch (error) {
      console.error('Error loading profile:', error);
      const loadingDiv = document.getElementById('loading');
      if (loadingDiv) {
        loadingDiv.innerHTML = `<p class="text-red-500">Lỗi: ${error.message}</p>`;
      }
    }
  }

  // Function removed - now using shared calculateUserStats from utils

  // Store current view state
  let currentUser: any = null;
  let allChallengeStats: any[] = [];
  let currentViewChallengeId: number | null = null;
  let allUsers: any[] = []; // Store all users for sidebar
  let currentSidebarChallengeFilter: string | null = null; // Store current challenge filter

  function displayProfile(user, challengeStats, allRecords) {
    currentUser = user;
    allChallengeStats = challengeStats;
    
    // Set current view to latest challenge (highest ID) if not set
    if (!currentViewChallengeId && challengeStats.length > 0) {
      // Sort by challengeId descending to get the latest challenge
      const sortedStats = [...challengeStats].sort((a, b) => b.challengeId - a.challengeId);
      currentViewChallengeId = sortedStats[0].challengeId;
    }
    
    // Render challenge selector
    renderChallengeSelector(user, challengeStats);
    
    // User header
    const userNameEl = document.getElementById('userName');
    const userBioEl = document.getElementById('userBio');
    const userMetaEl = document.getElementById('userMeta');

    if (userNameEl) userNameEl.textContent = user.name;
    if (userBioEl) {
      // Thay \n thành <br> để hiển thị xuống dòng đúng cách
      const bioWithBreaks = (user.bio || 'Không có bio').replace(/\n/g, '<br>');
      userBioEl.innerHTML = bioWithBreaks;
    }
    if (userMetaEl) {
      userMetaEl.innerHTML = `
        ${user.learningLanguage ? `<span class="px-3 py-1 rounded-full text-sm font-semibold bg-cyan-500/10 text-cyan-200 border border-cyan-400/20">🌐 ${user.learningLanguage}</span>` : ''}
        ${user.major ? `<span class="px-3 py-1 rounded-full text-sm font-semibold bg-fuchsia-500/10 text-fuchsia-200 border border-fuchsia-400/20">🎓 ${user.major}</span>` : ''}
        ${user.birthYear ? `<span class="px-3 py-1 rounded-full text-sm font-semibold bg-emerald-500/10 text-emerald-200 border border-emerald-400/20">📅 ${user.birthYear}</span>` : ''}
        ${user.discordNickname ? `<span class="px-3 py-1 rounded-full text-sm font-semibold bg-white/5 text-slate-200 border border-white/10">💬 ${user.discordNickname}</span>` : ''}
      `;
    }

    // Stats grid - show current selected challenge or first challenge
    updateStatsDisplay(challengeStats);

    // Display certificates
    displayCertificates(user, challengeStats);

    // Calendar view - display current challenge only
    const displayStats = currentViewChallengeId 
      ? challengeStats.filter(s => s.challengeId === currentViewChallengeId)
      : [challengeStats[0]];
    
    displayCalendars(displayStats);

    // Monthly breakdown
    displayMonthlyStats(displayStats);
  }

  function displayCertificates(user: any, challengeStats: any) {
    const certificatesListEl = document.getElementById('certificatesList');
    const noCertificatesEl = document.getElementById('noCertificates');
    
    if (!certificatesListEl) return;

    // Filter challenges that user has participated in and meet criteria
    // For now, show certificates for all challenges the user participated in
    const eligibleChallenges = challengeStats.filter((stat: any) => {
      // You can add criteria here, e.g., minimum attendance rate
      // return stat.disciplinePercentage >= 50; // At least 50% attendance
      return true; // Show all for now
    });

    if (eligibleChallenges.length === 0) {
      certificatesListEl.innerHTML = '';
      if (noCertificatesEl) noCertificatesEl.classList.remove('hidden');
      return;
    }

    if (noCertificatesEl) noCertificatesEl.classList.add('hidden');
    
    // DEBUG MODE: Log certificate data
    console.log('🔍 [CERT DEBUG] Starting certificate rendering...');
    console.log('🔍 [CERT DEBUG] Eligible challenges:', eligibleChallenges.length);

    certificatesListEl.innerHTML = eligibleChallenges.map((stat: any) => {
      const challengeName = challengeNames[stat.challengeId] || 'Unknown Challenge';
      const dateRange = challengeDateRanges[stat.challengeId];
      const startDate = new Date(dateRange.start);
      const endDate = new Date(dateRange.end);
      const today = new Date();
      const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
      const effectiveEndDate = todayStr < dateRange.end ? todayStr : dateRange.end;
      const daysSoFar = Math.ceil((new Date(effectiveEndDate) - startDate) / (1000 * 60 * 60 * 24)) + 1;
      const disciplinePercentage = Math.round((stat.totalDays / daysSoFar) * 100);
      
      // Xác định trạng thái: completed nếu đã kết thúc hoặc đạt 100%, progress nếu đang diễn ra
      const isCompleted = todayStr >= dateRange.end || disciplinePercentage >= 100;
      const cardClass = isCompleted ? 'cert-card completed' : 'cert-card progress';
      const statusBadge = isCompleted 
        ? '<span class="cert-status-badge status-done">Hoàn thành</span>'
        : '<span class="cert-status-badge status-doing">Đang diễn ra</span>';
      const statusText = isCompleted ? 'Hoàn thành xuất sắc' : 'Đang tham gia';
      const watermarkSvg = isCompleted
        ? `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 21h8"></path><path d="M12 17v4"></path><path d="M7 4h10v2a5 5 0 0 1-10 0V4z"></path><path d="M5 6H3a3 3 0 0 0 3 3"></path><path d="M19 6h2a3 3 0 0 1-3 3"></path></svg>`
        : `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 22h14"></path><path d="M5 2h14"></path><path d="M17 2v6.5a5 5 0 0 1-1.46 3.54L12 15.59l-3.54-3.55A5 5 0 0 1 7 8.5V2"></path><path d="M7 22v-6.5a5 5 0 0 1 1.46-3.54L12 8.41l3.54 3.55A5 5 0 0 1 17 15.5V22"></path></svg>`;
      const buttonHtml = isCompleted
        ? `<button class="btn-download-cert" onclick="downloadCertificate(${user.id}, ${stat.challengeId}, 'html')">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Tải chứng chỉ
            </button>`
        : `<button class="btn-download-cert cert-button-disabled" disabled>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
              Chưa đủ điều kiện
            </button>`;

      // DEBUG: Log certificate data
      console.log(`🔍 [CERT DEBUG] Challenge ${stat.challengeId}:`, {
        challengeName,
        isCompleted,
        totalDays: stat.totalDays,
        daysSoFar,
        disciplinePercentage,
        cardClass,
        statusText
      });

      return `
        <div class="${cardClass}" data-user-id="${user.id}" data-challenge-id="${stat.challengeId}" data-debug-challenge="${challengeName}">
          <div class="cert-accent" aria-hidden="true"></div>
          <div class="cert-watermark" aria-hidden="true">${watermarkSvg}</div>
          ${statusBadge}
          
          <div class="cert-body">
            <div class="cert-header">
              <div>
                <h3 class="cert-title text-lg sm:text-xl font-bold text-slate-100 m-0 leading-tight">${challengeName}</h3>
                <p class="cert-subtitle text-xs sm:text-sm text-slate-400 m-0 mt-1">${statusText}</p>
              </div>
            </div>

            <div class="cert-stats-row">
              <div class="cert-stat">
                <div class="cert-stat-val text-slate-100">${stat.totalDays}<span class="text-xs sm:text-sm text-slate-500 font-semibold">/${daysSoFar}</span></div>
                <div class="cert-stat-label">Ngày học</div>
              </div>
              <div class="cert-stat">
                <div class="cert-stat-val ${isCompleted ? 'text-emerald-300' : 'text-yellow-300'}">${disciplinePercentage}<span class="text-xs sm:text-sm text-slate-500 font-semibold">%</span></div>
                <div class="cert-stat-label">Kỷ luật</div>
              </div>
            </div>
          </div>

          <div class="cert-footer">
            ${buttonHtml}
          </div>
        </div>
      `;
    }).join('');
    
    // DEBUG MODE: After rendering, analyze computed styles
    setTimeout(() => {
      console.log('🔍 [CERT DEBUG] Analyzing rendered certificates...');
      const cards = certificatesListEl.querySelectorAll('.cert-card');
      cards.forEach((card, index) => {
        const challengeName = card.getAttribute('data-debug-challenge');
        console.log(`\n🔍 [CERT DEBUG] Card ${index + 1}: ${challengeName}`);
        
        // Check card styles
        const cardStyles = window.getComputedStyle(card);
        console.log('  📦 Card:');
        console.log('    - padding:', cardStyles.padding);
        console.log('    - borderRadius:', cardStyles.borderRadius);
        console.log('    - borderLeft:', cardStyles.borderLeft);
        console.log('    - backgroundColor:', cardStyles.backgroundColor);
        console.log('    - boxShadow:', cardStyles.boxShadow);
        
        // Check icon
        const iconBg = card.querySelector('.cert-icon-bg');
        if (iconBg) {
          const iconStyles = window.getComputedStyle(iconBg);
          console.log('  🎨 Icon BG:');
          console.log('    - width:', iconStyles.width, '(expected: 48px)');
          console.log('    - height:', iconStyles.height, '(expected: 48px)');
          console.log('    - borderRadius:', iconStyles.borderRadius, '(expected: 12px)');
          console.log('    - backgroundColor:', iconStyles.backgroundColor);
          console.log('    - color:', iconStyles.color);
        }
        
        // Check title
        const title = card.querySelector('.cert-title');
        if (title) {
          const titleStyles = window.getComputedStyle(title);
          console.log('  📝 Title:');
