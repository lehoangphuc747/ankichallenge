    <script>
      function autoFitText(selector, maxSizePt, minSizePt, maxLines) {
        const element = document.querySelector(selector);
        if (!element) return;

        element.style.fontSize = maxSizePt + 'pt';
        let currentSize = maxSizePt;

        while (currentSize > minSizePt) {
          const computed = window.getComputedStyle(element);
          const lineHeight = parseFloat(computed.lineHeight) || currentSize * 1.2;
          const maxHeight = lineHeight * maxLines + 2;
          const overflowsWidth = element.scrollWidth > element.clientWidth + 1;
          const overflowsHeight = element.scrollHeight > maxHeight;

          if (!overflowsWidth && !overflowsHeight) break;

          currentSize -= 1;
          element.style.fontSize = currentSize + 'pt';
        }
      }

      function fitCertificate() {
        const viewport = document.querySelector('.viewport');
        const container = document.querySelector('.container');
        if (!viewport || !container) return;

        autoFitText('.user-name', 44, 26, 3);
        autoFitText('.challenge-name', 36, 24, 2);

        const baseWidth = container.offsetWidth;
        const baseHeight = container.offsetHeight;
        if (!baseWidth || !baseHeight) return;

        const viewportWidth = viewport.clientWidth;
        const viewportHeight = Math.max(320, window.innerHeight - 32);
        const scale = Math.min(1, viewportWidth / baseWidth, viewportHeight / baseHeight);

        container.style.setProperty('--cert-scale', String(scale));
        viewport.style.height = (baseHeight * scale) + 'px';
      }

      window.addEventListener('resize', fitCertificate);
      window.addEventListener('orientationchange', fitCertificate);
      fitCertificate();
    <\/script>
</body>
</html>`;
