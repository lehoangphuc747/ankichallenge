  // Sidebar functions
  function renderSidebar(currentUserId: string | number, challengeFilterId: string = 'all') {
    const sidebarListEl = document.getElementById('sidebarUserList') as HTMLDivElement | null;
    if (!sidebarListEl || !allUsers || allUsers.length === 0) {
      return;
    }

    // Filter users by challenge if filter is set
    let filteredUsers = allUsers;
    if (challengeFilterId && challengeFilterId !== 'all') {
      filteredUsers = allUsers.filter(user => {
        const userChallengeIds = user.challengeIds || [];
        return userChallengeIds.includes(parseInt(challengeFilterId));
      });
    }

    // Sort users alphabetically by name
    const sortedUsers = [...filteredUsers].sort((a, b) => {
      const nameA = (a.name || '').toLowerCase();
      const nameB = (b.name || '').toLowerCase();
      return nameA.localeCompare(nameB, 'vi');
    });

    if (sortedUsers.length === 0) {
      const challengeName = challengeFilterId && challengeFilterId !== 'all' 
        ? challengeNames[challengeFilterId] || `Challenge ${challengeFilterId}`
        : 'challenge này';
      sidebarListEl.innerHTML = `
        <div class="text-center py-8 text-slate-400">
          <p class="font-semibold mb-2">Không có thành viên nào</p>
          <p class="text-sm">Chưa có ai tham gia ${challengeName}</p>
        </div>
      `;
      return;
    }

    sidebarListEl.innerHTML = sortedUsers.map(user => {
      const isActive = user.id.toString() === currentUserId.toString();
      const safeName = user.name || 'Không tên';
      const safeLanguage = user.learningLanguage || '';
      const safeDiscord = user.discordNickname || '';
      
      return `
        <a 
          href="/profile/${user.id}" 
          class="sidebar-member-card ${isActive ? 'sidebar-member-card-active' : ''}"
          data-user-id="${user.id}"
          data-user-name="${safeName.toLowerCase()}"
          data-user-language="${safeLanguage.toLowerCase()}"
          data-user-discord="${safeDiscord.toLowerCase()}"
        >
          <div class="sidebar-member-row">
            <div class="sidebar-member-avatar ${isActive ? 'sidebar-member-avatar-active' : ''}">
              ${safeName ? safeName.charAt(0).toUpperCase() : '?'}
            </div>
            <div class="sidebar-member-main">
              <div class="sidebar-member-name">
                ${safeName}
              </div>
              ${safeLanguage ? `
                <div class="sidebar-member-language">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M2 12h20"></path>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                  </svg>
                  <span>${safeLanguage}</span>
                </div>
              ` : ''}
            </div>
            ${isActive ? `
              <div class="sidebar-member-check" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
            ` : ''}
          </div>
        </a>
      `;
    }).join('');

    // Scroll active user into view
    setTimeout(() => {
      const activeLink = sidebarListEl.querySelector(`[data-user-id="${currentUserId}"]`);
      if (activeLink) {
        activeLink.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }, 100);
  }

  // Sidebar search functionality
  function setupSidebarSearch() {
    const searchInput = document.getElementById('sidebarSearch') as HTMLInputElement | null;
    if (!searchInput) return;

    const performSearch = () => {
      const query = searchInput.value.toLowerCase().trim();
      const userLinks = document.querySelectorAll<HTMLAnchorElement>('#sidebarUserList a[data-user-id]');
      
      userLinks.forEach(link => {
        const userName = link.dataset.userName || '';
        const userLanguage = link.dataset.userLanguage || '';
        const userDiscord = link.dataset.userDiscord || '';
        
        if (query === '' || userName.includes(query) || userLanguage.includes(query) || userDiscord.includes(query)) {
          link.style.display = 'block';
        } else {
          link.style.display = 'none';
        }
      });
    };

    searchInput.addEventListener('input', performSearch);
  }

  // Sidebar challenge filter functionality
  function setupSidebarChallengeFilter() {
    const challengeFilter = document.getElementById('sidebarChallengeFilter') as HTMLSelectElement | null;
    if (!challengeFilter) return;

    // Set default value
    if (currentSidebarChallengeFilter) {
      challengeFilter.value = currentSidebarChallengeFilter;
    }

    challengeFilter.addEventListener('change', (e) => {
      const selectedChallengeId = (e.target as HTMLSelectElement).value;
      currentSidebarChallengeFilter = selectedChallengeId;
      
      // Re-render sidebar with new filter
      const pathParts = window.location.pathname.split('/').filter(Boolean);
      const currentUserId = pathParts[pathParts.length - 1];
      renderSidebar(currentUserId, selectedChallengeId);
      
      // Clear search input when filter changes
      const searchInput = document.getElementById('sidebarSearch') as HTMLInputElement | null;
      if (searchInput) {
        searchInput.value = '';
      }
    });
  }

  // Sidebar toggle functionality
  function setupSidebarToggle() {
    const sidebar = document.getElementById('profileSidebar');
    const sidebarToggle = document.getElementById('sidebarToggle');
    const sidebarClose = document.getElementById('sidebarClose');
    const sidebarOverlay = document.getElementById('sidebarOverlay');

    if (!sidebar || !sidebarToggle || !sidebarClose || !sidebarOverlay) return;

    const openSidebar = () => {
      sidebar.classList.remove('-translate-x-full');
      sidebarOverlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    };

    const closeSidebar = () => {
      sidebar.classList.add('-translate-x-full');
      sidebarOverlay.classList.add('hidden');
      document.body.style.overflow = '';
    };

    sidebarToggle.addEventListener('click', openSidebar);
    sidebarClose.addEventListener('click', closeSidebar);
    sidebarOverlay.addEventListener('click', closeSidebar);

    // Close sidebar when clicking on a user link (mobile) - use event delegation
    const sidebarListEl = document.getElementById('sidebarUserList');
    if (sidebarListEl) {
      sidebarListEl.addEventListener('click', (e) => {
        const target = e.target as HTMLElement | null;
        const link = target?.closest('a[data-user-id]');
        if (link && window.innerWidth < 768) {
          closeSidebar();
        }
      });
    }
  }

  // Initialize sidebar functionality after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setupSidebarSearch();
      setupSidebarChallengeFilter();
      setupSidebarToggle();
    });
  } else {
    setupSidebarSearch();
    setupSidebarChallengeFilter();
    setupSidebarToggle();
  }

  // Load profile on page load
  loadProfile();
</script>

