---
import Layout from "../layouts/Layout.astro";

const googleFormId = "1FAIpQLSfoZmv7DYnzYQh66e1kToCF1czcR8GZzuG0L2LB3ZEpBq0vNA";
const googleFormViewUrl = `https://docs.google.com/forms/d/e/${googleFormId}/viewform`;
const googleFormActionUrl = `https://docs.google.com/forms/d/e/${googleFormId}/formResponse`;
const googleFormFbzx = "5793887780826789600";
---

<Layout title="Anki Challenge 10 - Đăng ký">
  <main class="page-wrap">
    <div class="geo geo-1" aria-hidden="true"></div>
    <div class="geo geo-2" aria-hidden="true"></div>

    <section class="hero card">
      <p class="eyebrow">Anki Challenge 10 | 100 days</p>
      <h1>Đăng ký Anki Challenge 10</h1>
      <div style="margin: 0.8rem 0 1.2rem 0;">
        <span style="display: inline-block; background: rgba(0, 255, 148, 0.15); color: #4affb5; padding: 0.45rem 1.2rem; border-radius: 30px; font-weight: 600; font-size: 0.95rem; border: 1px solid rgba(0, 255, 148, 0.4); letter-spacing: 0.02em;">
          🚀 Ngày bắt đầu: 10/04/2026 (Thứ 6)
        </span>
      </div>
      <p>
        Frontend tự xử lý form. Dữ liệu được gửi trực tiếp vào Google Form để dùng làm response database.
      </p>
    </section>

    <section class="card form-card">
      <!-- Step Indicators -->
      <div class="step-indicators">
        <div class="step-indicator step-indicator-active" data-step="1">
          <div class="step-number">1</div>
          <div class="step-label">Cam kết</div>
        </div>
        <div class="step-indicator-connector"></div>
        <div class="step-indicator" data-step="2">
          <div class="step-number">2</div>
          <div class="step-label">Lộ trình</div>
        </div>
        <div class="step-indicator-connector"></div>
        <div class="step-indicator" data-step="3">
          <div class="step-number">3</div>
          <div class="step-label">Thông tin</div>
        </div>
      </div>

      <form id="ac10Form" action={googleFormActionUrl} method="POST" target="ac10SubmitSink" novalidate>
        
        <!-- STEP 1: Cam kết -->
        <div id="commitmentSection" class="step-container step-active">
          <div class="grid">
            <fieldset class="radio-group" style="grid-column: 1 / -1;">
              <legend>Cam kết <span class="required-mark" aria-hidden="true">*</span></legend>
              <div class="radio-options">
                <label class="radio-label">
                  <input type="radio" name="entry.1772885244" value="Tôi cam kết" id="commitYes" required />
                  <span>Tôi cam kết</span>
                </label>
                <label class="radio-label">
                  <input type="radio" name="entry.1772885244" value="Tôi cần cân nhắc thêm" id="commitNo" required />
                  <span>Tôi cần cân nhắc thêm</span>
                </label>
              </div>
            </fieldset>
          </div>
        </div>

        <!-- STEP 2: Challenge 9 (Path decision) -->
        <div id="challenge9Section" class="step-container hidden" style="margin-top: 1.2rem;">
          <div class="grid">
            <fieldset class="radio-group" style="grid-column: 1 / -1;">
              <legend>Bạn đã từng tham gia (và hoàn thành (tổng) trên 95 ngày) Anki Challenge trước đây chưa? <span class="required-mark" aria-hidden="true">*</span></legend>
              <div class="radio-options">
                <label class="radio-label">
                  <input 
                    type="radio" 
                    name="entry.1782122629" 
                    value="Chính xác 😎" 
                    id="challenge9Yes"
                    required 
                  />
                  <span>Đã từng hoàn thành 😎</span>
                </label>
                <label class="radio-label">
                  <input 
                    type="radio" 
                    name="entry.1782122629" 
                    value="Ờm...." 
                    id="challenge9No"
                    required 
                  />
                  <span>Chưa (hoặc tham gia không đầy đủ)</span>
                </label>
              </div>
            </fieldset>
          </div>
        </div>

        <!-- PATH A: Congratulatory Banner & QR -->
        <div id="pathABanner" class="hidden" style="margin-top: 1.5rem;">
          <div class="success-banner" role="status" aria-live="polite">
            <h2>🎉 Chào mừng học viên cũ trở lại!</h2>
            <p>Bạn có quyền tham gia Challenge 10 mà <strong>không cần đóng tiền</strong>. Tuy nhiên, nếu bạn muốn đóng góp hỗ trợ quỹ Nuôi Phúc thì không ai cấm!!!</p>
            <div class="qr-wrapper">
              <div class="qr-container">
                <img src="/images/challenge10-qr.png" alt="QR Code" width="150" height="150" />
              </div>
              <div class="bank-details">
                <p class="stk-row">
                  <strong>STK:</strong> 
                  <span class="stk-number">TIMOF8C0F5B5161</span>
                  <button type="button" class="copy-btn" title="Sao chép số tài khoản" onclick="const btn = event.currentTarget; navigator.clipboard.writeText('TIMOF8C0F5B5161').then(() => { const old = btn.innerText; btn.innerText = 'Đã chép ✓'; setTimeout(() => btn.innerText = old, 2000); })">Copy</button>
                </p>
                <p><strong>Tên tài khoản:</strong> LE HOANG PHUC</p>
                <p><strong>Ngân hàng:</strong> Timo Digital Bank by BVBank</p>
              </div>
              <div class="qr-note stk-row" style="color: #98d7ff !important; margin-top: 0 !important;">
                <em>Nội dung:</em>
                <span class="stk-number">anki 10</span>
                <button type="button" class="copy-btn" title="Sao chép nội dung" onclick="const btn = event.currentTarget; navigator.clipboard.writeText('anki 10').then(() => { const old = btn.innerText; btn.innerText = 'Đã chép ✓'; setTimeout(() => btn.innerText = old, 2000); })">Copy</button>
              </div>
            </div>
          </div>
          
          <div id="discordLookupContainer" style="margin-top: 1rem;">
            <div class="lookup-section">
              <h3>Chọn Discord Nickname để tự động lấy thông tin</h3>
              <div class="picker-field">
                <span class="picker-label">Discord Nickname</span>
                <button
                  type="button"
                  id="discordPickerTrigger"
                  class="picker-trigger"
                  aria-haspopup="dialog"
                  aria-expanded="false"
                  aria-controls="discordPickerModal"
                >
                  <span id="discordPickerValue">Nhấn để chọn nickname từ danh sách</span>
                </button>
              </div>
              <p id="discordLookupHint" class="hint-text">Mở danh sách, gõ để lọc nhanh rồi chọn đúng nickname đã dùng ở Challenge trước.</p>
              <p id="lookupMessage" class="helper hidden" aria-live="polite"></p>
            </div>

            <div id="discordPickerModal" class="picker-modal hidden" role="dialog" aria-modal="true" aria-labelledby="discordPickerTitle">
              <div id="discordPickerOverlay" class="picker-modal-overlay" aria-hidden="true"></div>
              <div class="picker-modal-panel">
                <div class="picker-modal-head">
                  <h4 id="discordPickerTitle">Chọn Discord Nickname</h4>
                  <button type="button" id="discordPickerClose" class="picker-close-btn" aria-label="Đóng popup chọn nickname">Đóng</button>
                </div>
                <div class="picker-search-wrap">
                  <label for="discordPickerSearch" class="sr-only">Tìm nhanh nickname</label>
                  <div class="search-input-box">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <input
                      id="discordPickerSearch"
                      type="text"
                      placeholder="Gõ nickname Discord hoặc tên thật..."
                      autocomplete="off"
                    />
                  </div>
                </div>
                <div id="discordPickerList" class="picker-list" role="listbox" aria-label="Danh sách Discord nickname"></div>
                <div id="discordPickerEmpty" class="picker-empty hidden">
                  <span style="font-size: 1.5rem; display: block; margin-bottom: 0.5rem;">🔍</span>
                  Không tìm thấy nickname nào phù hợp.
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- PATH B: Trạng thái đóng phí -->
        <div id="feeSection" class="hidden" style="margin-top: 1.2rem;">
          <div class="grid">
            <div class="payment-banner" style="grid-column: 1 / -1;">
              <h3>Đóng phí tham gia Challenge 10</h3>
              <p>Yêu cầu đóng phí <strong>50.000 VNĐ</strong> để tham gia. Vui lòng quét QR bên dưới để chuyển khoản, sau đó chọn <strong>Đã đóng phí</strong> để mở bước nhập thông tin.</p>
              <div class="qr-wrapper">
                <div class="qr-container">
                  <img src="/images/challenge10-qr.png" alt="QR Code thanh toán Challenge 10" width="150" height="150" />
                </div>
                <div class="bank-details">
                  <p class="stk-row">
                    <strong>STK:</strong> 
                    <span class="stk-number">TIMOF8C0F5B5161</span>
                    <button type="button" class="copy-btn" title="Sao chép số tài khoản" onclick="const btn = event.currentTarget; navigator.clipboard.writeText('TIMOF8C0F5B5161').then(() => { const old = btn.innerText; btn.innerText = 'Đã chép ✓'; setTimeout(() => btn.innerText = old, 2000); })">Copy</button>
                  </p>
                  <p><strong>Tên tài khoản:</strong> LE HOANG PHUC</p>
                  <p><strong>Ngân hàng:</strong> Timo Digital Bank by BVBank</p>
                </div>
                <div class="qr-note stk-row" style="color: #4affb5 !important; margin-top: 0 !important;">
                  <em>Nội dung:</em>
                  <span class="stk-number">anki 10</span>
                  <button type="button" class="copy-btn" title="Sao chép nội dung" onclick="const btn = event.currentTarget; navigator.clipboard.writeText('anki 10').then(() => { const old = btn.innerText; btn.innerText = 'Đã chép ✓'; setTimeout(() => btn.innerText = old, 2000); })">Copy</button>
                </div>
              </div>
            </div>

            <fieldset class="radio-group" style="grid-column: 1 / -1; margin-top: 1rem;">
              <legend>Trạng thái đóng phí <span id="feeRequiredMark" class="required-mark" aria-hidden="true">*</span></legend>
              <div class="radio-options">
                <label class="radio-label">
                  <input type="radio" name="entry.1998486890" value="Đã đóng phí" id="feePaid" required />
                  <span>Đã đóng phí</span>
                </label>
                <label class="radio-label">
                  <input type="radio" name="entry.1998486890" value="Chưa đóng phí" id="feeUnpaid" required />
                  <span>Chưa đóng phí</span>
                </label>
              </div>
            </fieldset>
          </div>
        </div>

        <!-- STEP 3: Info Fields -->
        <div id="infoSection" class="step-container hidden" style="margin-top: 1.2rem;">
          <div class="grid">
            <label>
              <span>Họ và tên</span>
              <input name="entry.582716327" type="text" placeholder="Lê Hoàng Phúc" required />
            </label>

            <label>
              <span>Năm sinh</span>
              <input name="entry.182062064" type="text" inputmode="numeric" pattern="[0-9]{4}" placeholder="2001" required />
            </label>

            <label>
              <span>Nơi sinh sống</span>
              <input name="entry.177391751" type="text" placeholder="Chuncheon" required />
            </label>

            <div class="input-with-btn">
              <label>
                <span>Link Facebook</span>
                <input name="entry.1749653006" type="text" placeholder="fb.com/..." required />
              </label>
              <button type="button" class="help-btn" onclick="window.open('https://www.facebook.com/me', '_blank')">
                Lấy link FB
              </button>
            </div>

            <label>
              <span>Số điện thoại</span>
              <input name="entry.460661342" type="tel" inputmode="numeric" pattern="0[0-9]{9}" title="Số điện thoại phải bắt đầu với 0 và có đúng 10 số" placeholder="0346598402" required />
            </label>

            <label>
              <span>Nickname trong Discord</span>
              <input name="entry.2074934601" type="text" placeholder="madbear" required />
            </label>

            <label>
              <span>Giới thiệu bản thân</span>
              <input name="entry.346765928" type="text" placeholder="Học 30 phút/ngày" required />
            </label>

            <label>
              <span>Quote tâm đắc</span>
              <input name="entry.909708031" type="text" placeholder="Nếu bạn không thay đổi, đó là vì bạn không muốn thay đổi." />
            </label>

            <label style="grid-column: 1 / -1;">
              <span>Chia sẻ lĩnh vực bạn đang dùng anki để học</span>
              <input name="entry.1768034029" type="text" placeholder="tiếng Hàn" required />
            </label>
          </div>
        </div>

        <input type="hidden" name="fvv" value="1" />
        <input type="hidden" name="pageHistory" value="0" />
        <input type="hidden" name="fbzx" value={googleFormFbzx} />
        <input type="hidden" name="draftResponse" value="[]" />

        <p id="flowAnnouncer" class="sr-only" aria-live="polite"></p>
        <p class="helper" id="formMessage" role="status" aria-live="polite"></p>

        <div class="actions hidden" id="submitActions">
          <button id="submitBtn" type="submit">
            <span id="submitBtnLabel">Gửi đăng ký</span>
            <span id="submitBtnSpinner" class="btn-spinner hidden" aria-hidden="true"></span>
          </button>
        </div>
      </form>

      <iframe name="ac10SubmitSink" class="hidden" title="Submit sink"></iframe>
    </section>

    <section class="card success-card hidden" id="successCard">
      <h2>Đăng ký thành công</h2>
      <p>
        Hệ thống đã gửi dữ liệu lên Google Form. Bạn có thể liên hệ admin để xử lý sau đó ngồi chơi xơi nước đợi.
      </p>
      <a class="ghost-btn" href="https://www.facebook.com/tui.la.phuc747/" target="_blank" rel="noopener noreferrer">
        Liên hệ admin để được thêm vào challenge
      </a>
    </section>
  </main>
</Layout>

<script>
  type CompleterRecord = {
    id?: number;
    name?: string;
    birthYear?: number;
    facebookUrl?: string;
    discordNickname: string;
    hidden?: boolean;
    role?: string;
    challengeIds?: number[];
  };
  type ValidField = HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;

  const form = document.getElementById("ac10Form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submitBtn") as HTMLButtonElement | null;
  const submitActions = document.getElementById("submitActions") as HTMLDivElement | null;
  const submitBtnLabel = document.getElementById("submitBtnLabel") as HTMLSpanElement | null;
  const submitBtnSpinner = document.getElementById("submitBtnSpinner") as HTMLSpanElement | null;
  const message = document.getElementById("formMessage") as HTMLParagraphElement | null;
  const flowAnnouncer = document.getElementById("flowAnnouncer") as HTMLParagraphElement | null;
  const successCard = document.getElementById("successCard") as HTMLElement | null;
  const submitSink = document.querySelector('iframe[name="ac10SubmitSink"]');
  
  // Auto-fill related elements
  const challenge9Section = document.getElementById("challenge9Section") as HTMLElement | null;
  const challenge9Yes = document.getElementById("challenge9Yes") as HTMLInputElement | null;
  const challenge9No = document.getElementById("challenge9No") as HTMLInputElement | null;
  const discordLookupContainer = document.getElementById("discordLookupContainer") as HTMLElement | null;
  const discordPickerTrigger = document.getElementById("discordPickerTrigger") as HTMLButtonElement | null;
  const discordPickerValue = document.getElementById("discordPickerValue") as HTMLSpanElement | null;
  const discordPickerModal = document.getElementById("discordPickerModal") as HTMLDivElement | null;
  const discordPickerOverlay = document.getElementById("discordPickerOverlay") as HTMLDivElement | null;
  const discordPickerClose = document.getElementById("discordPickerClose") as HTMLButtonElement | null;
  const discordPickerSearch = document.getElementById("discordPickerSearch") as HTMLInputElement | null;
  const discordPickerList = document.getElementById("discordPickerList") as HTMLDivElement | null;
  const discordPickerEmpty = document.getElementById("discordPickerEmpty") as HTMLParagraphElement | null;
  const lookupMessage = document.getElementById("lookupMessage") as HTMLParagraphElement | null;
  
  // Conditional flow elements
  const commitmentSection = document.getElementById("commitmentSection") as HTMLElement | null;
  const commitYes = document.getElementById("commitYes") as HTMLInputElement | null;
  const commitNo = document.getElementById("commitNo") as HTMLInputElement | null;
  const pathABanner = document.getElementById("pathABanner") as HTMLElement | null;
  const feeSection = document.getElementById("feeSection") as HTMLElement | null;
  const feeRequiredMark = document.getElementById("feeRequiredMark") as HTMLElement | null;
  const feePaid = document.getElementById("feePaid") as HTMLInputElement | null;
  const feeUnpaid = document.getElementById("feeUnpaid") as HTMLInputElement | null;
  const infoSection = document.getElementById("infoSection") as HTMLElement | null;
  
  // Excellence completers data (cached)
  let excellenceCompleters: CompleterRecord[] | null = null;
  let pickerFilteredCompleters: CompleterRecord[] = [];

  function showLookupMessage(text: string, tone = "helper") {
    if (!lookupMessage) {
      return;
    }

    lookupMessage.textContent = text;
    lookupMessage.className = tone;
    lookupMessage.classList.remove("hidden");
  }

  function updateFlowAnnouncement(text: string) {
    if (flowAnnouncer) {
      flowAnnouncer.textContent = text;
    }
  }

  function isValidFacebookLink(value: string) {
    const normalized = value.trim().toLowerCase();

    if (!normalized) {
      return false;
    }

    return normalized.includes("fb.com") || normalized.includes("facebook.com");
  }

  function syncSpecialFieldValidity(field: ValidField) {
    field.setCustomValidity("");

    const fieldName = field.getAttribute("name");
    if (fieldName !== "entry.1749653006" || !(field instanceof HTMLInputElement)) {
      return;
    }

    if (!field.value.trim()) {
      field.setCustomValidity("Trường này là bắt buộc.");
      return;
    }

    if (!isValidFacebookLink(field.value)) {
      field.setCustomValidity("Link Facebook phải chứa fb.com hoặc facebook.com.");
    }
  }

  function addRequiredMarkers() {
    if (!(form instanceof HTMLFormElement)) {
      return;
    }

    form.querySelectorAll("label").forEach((label) => {
      const requiredField = label.querySelector("input[required], select[required], textarea[required]");
      const title = label.querySelector("span");

      if (requiredField && title) {
        title.classList.add("required-label");
      }
    });
  }

  function syncRadioVisualState(groupName: string) {
    if (!(form instanceof HTMLFormElement)) {
      return;
    }

    const radios = form.querySelectorAll<HTMLInputElement>(`input[type="radio"][name="${groupName}"]`);
    radios.forEach((radio) => {
      const label = radio.closest("label");
      if (!label) {
        return;
      }
      label.classList.toggle("is-selected", radio.checked);
    });
  }

  function setupRadioVisualState() {
    if (!(form instanceof HTMLFormElement)) {
      return;
    }

    const groupNames = new Set<string>();
    form.querySelectorAll<HTMLInputElement>('input[type="radio"][name]').forEach((radio) => {
      groupNames.add(radio.name);
      radio.addEventListener("change", () => {
        syncRadioVisualState(radio.name);
      });
    });

    groupNames.forEach((groupName) => {
      syncRadioVisualState(groupName);
    });
  }

  function updateStepIndicators() {
    const indicators = document.querySelectorAll<HTMLElement>('.step-indicator');
    
    const step1Active = commitmentSection && !commitmentSection.classList.contains('hidden');
    const step2Active = challenge9Section && !challenge9Section.classList.contains('hidden');
    const step3Active = infoSection && !infoSection.classList.contains('hidden');

    indicators.forEach((indicator) => {
      const step = indicator.getAttribute('data-step');
      indicator.classList.remove('step-indicator-active');
      if (step === '1' && step1Active) {
        indicator.classList.add('step-indicator-active');
      } else if (step === '2' && step2Active) {
        indicator.classList.add('step-indicator-active');
      } else if (step === '3' && step3Active) {
        indicator.classList.add('step-indicator-active');
      }
    });
  }

  function getFieldErrorElement(field: ValidField): HTMLParagraphElement | null {
    const fieldset = field.closest("fieldset.radio-group");
    if (fieldset) {
      let errorEl = fieldset.querySelector<HTMLParagraphElement>(".field-error");
      if (!errorEl) {
        errorEl = document.createElement("p");
        errorEl.className = "field-error";
        errorEl.setAttribute("aria-live", "polite");
        fieldset.appendChild(errorEl);
      }
      return errorEl as HTMLParagraphElement;
    }

    const wrapper = field.closest("label") || field.closest(".input-with-btn") || field.parentElement;
    if (!wrapper) {
      return null;
    }

    let errorEl = wrapper.querySelector<HTMLParagraphElement>(".field-error");
    if (!errorEl) {
      errorEl = document.createElement("p");
      errorEl.className = "field-error";
      errorEl.setAttribute("aria-live", "polite");
      wrapper.appendChild(errorEl);
    }
    return errorEl as HTMLParagraphElement;
  }

  function getCustomFieldMessage(field: ValidField): string {
    const fieldName = field.getAttribute("name");

    if (field.validity.valueMissing) {
      return "Trường này là bắt buộc.";
    }

    if (fieldName === "entry.182062064" && field.validity.patternMismatch) {
      return "Năm sinh cần đúng 4 chữ số (ví dụ: 2001).";
    }

    if (fieldName === "entry.460661342" && field.validity.patternMismatch) {
      return "Số điện thoại phải bắt đầu bằng 0 và có đúng 10 số.";
    }

    if (fieldName === "entry.1749653006" && field.validationMessage) {
      return field.validationMessage;
    }

    return field.validationMessage || "Giá trị nhập chưa hợp lệ.";
  }

  function setFieldError(field: ValidField, text: string) {
    const errorEl = getFieldErrorElement(field);
    if (!errorEl) {
      return;
    }

    errorEl.textContent = text;
    errorEl.classList.add("visible");
    field.setAttribute("aria-invalid", "true");
  }

  function clearFieldError(field: ValidField) {
    const errorEl = getFieldErrorElement(field);
    if (errorEl) {
      errorEl.textContent = "";
      errorEl.classList.remove("visible");
    }
    field.removeAttribute("aria-invalid");
  }

  function clearAllFieldErrors() {
    if (!(form instanceof HTMLFormElement)) {
      return;
    }

    form.querySelectorAll(".field-error").forEach((el) => {
      el.textContent = "";
      el.classList.remove("visible");
    });

    form.querySelectorAll("[aria-invalid='true']").forEach((el) => {
      el.removeAttribute("aria-invalid");
    });
  }

  function isElementVisible(element: HTMLElement): boolean {
    const rect = element.getBoundingClientRect();
    return element.getClientRects().length > 0 && rect.width > 0 && rect.height > 0;
  }

  function validateVisibleFields() {
    if (!(form instanceof HTMLFormElement)) {
      return true;
    }

    clearAllFieldErrors();

    const candidates = Array.from(form.querySelectorAll<ValidField>("input, select, textarea"))
      .filter((field) => {
        if (!field.willValidate) {
          return false;
        }

        if (field instanceof HTMLInputElement && field.type === "hidden") {
          return false;
        }

        return isElementVisible(field);
      });

    const invalidFields = candidates.filter((field) => {
      syncSpecialFieldValidity(field);
      return !field.checkValidity();
    });

    if (invalidFields.length > 0) {
      invalidFields.forEach((field) => {
        setFieldError(field, getCustomFieldMessage(field));
      });

      invalidFields[0].focus();
      return false;
    }

    return true;
  }

  // Fetch excellence completers data
  async function loadExcellenceCompleters() {
    if (excellenceCompleters) return excellenceCompleters;
    try {
      const response = await fetch('/data/users.json');
      if (!response.ok) throw new Error('Failed to fetch');
      const json = await response.json();
      const users = (json.data || []) as CompleterRecord[];
      excellenceCompleters = users
        .filter((user) => 
          typeof user.discordNickname === "string" && 
          user.discordNickname.trim().length > 0 &&
          user.challengeIds && 
          user.challengeIds.includes(2)
        )
        .sort((a, b) => a.discordNickname.localeCompare(b.discordNickname, "vi"));
      pickerFilteredCompleters = [...excellenceCompleters];
      return excellenceCompleters;
    } catch (error) {
      console.error('Error loading excellence completers:', error);
      showLookupMessage("Lỗi tải dữ liệu. Vui lòng thử lại.", "helper error");
      return null;
    }
  }

  function resetPickerLabel() {
    if (discordPickerValue) {
      discordPickerValue.textContent = "Nhấn để chọn nickname từ danh sách";
    }
  }

  function openPickerModal() {
    if (!discordPickerModal || !discordPickerTrigger) {
      return;
    }

    discordPickerModal.classList.remove("hidden");
    discordPickerTrigger.setAttribute("aria-expanded", "true");
    if (discordPickerSearch) {
      discordPickerSearch.focus();
    }
  }

  function closePickerModal() {
    if (!discordPickerModal || !discordPickerTrigger) {
      return;
    }

    discordPickerModal.classList.add("hidden");
    discordPickerTrigger.setAttribute("aria-expanded", "false");
    discordPickerTrigger.focus();
  }

  function renderPickerList() {
    if (!discordPickerList || !discordPickerEmpty) {
      return;
    }

    discordPickerList.innerHTML = "";

    if (pickerFilteredCompleters.length === 0) {
      discordPickerEmpty.classList.remove("hidden");
      return;
    }

    discordPickerEmpty.classList.add("hidden");

    const fragment = document.createDocumentFragment();
    pickerFilteredCompleters.forEach((completer) => {
      const optionBtn = document.createElement("button");
      optionBtn.type = "button";
      optionBtn.className = "picker-option";
      optionBtn.setAttribute("role", "option");
      optionBtn.innerHTML = `
        <span class="picker-option-nick">${completer.discordNickname}</span>
        <span class="picker-option-name">${completer.name || "Không có tên"}</span>
      `;

      optionBtn.addEventListener("click", () => {
        if (discordPickerValue) {
          discordPickerValue.textContent = completer.discordNickname;
        }
        autoFillFields(completer);
        closePickerModal();
      });

      fragment.appendChild(optionBtn);
    });

    discordPickerList.appendChild(fragment);
  }

  function filterPickerList(keyword: string) {
    const source = excellenceCompleters ?? [];
    const searchTerm = keyword.trim().toLowerCase();

    if (!searchTerm) {
      pickerFilteredCompleters = [...source];
      renderPickerList();
      return;
    }

    pickerFilteredCompleters = source.filter((item) => {
      const nick = item.discordNickname.toLowerCase();
      const name = (item.name || "").toLowerCase();
      return nick.includes(searchTerm) || name.includes(searchTerm);
    });
    renderPickerList();
  }

  // Auto-fill form fields from excellence completer data
  function autoFillFields(completer: CompleterRecord) {
    if (!form) {
      return;
    }

    const nameInput = form.querySelector<HTMLInputElement>('input[name="entry.582716327"]');
    const birthYearInput = form.querySelector<HTMLInputElement>('input[name="entry.182062064"]');
    const facebookInput = form.querySelector<HTMLInputElement>('input[name="entry.1749653006"]');
    const nicknameInput = form.querySelector<HTMLInputElement>('input[name="entry.2074934601"]');
    
    if (nameInput) nameInput.value = completer.name || '';
    if (birthYearInput) birthYearInput.value = (completer.birthYear || '').toString();
    if (facebookInput) facebookInput.value = completer.facebookUrl || '';
    if (nicknameInput) nicknameInput.value = completer.discordNickname || '';
    
    showLookupMessage(`✓ Đã chọn: ${completer.discordNickname}. Bạn có thể chỉnh sửa các trường này.`, "helper success");
  }

  if (form instanceof HTMLFormElement && submitBtn && submitBtnLabel && submitBtnSpinner && message && successCard) {
    addRequiredMarkers();
    setupRadioVisualState();
    updateStepIndicators();

    let isSubmitting = false;
    let submitted = false;

    const isSubmitWorkflowOpen = () => {
      const choseCommitment = Boolean(commitYes?.checked);
      const choseChallenge9 = Boolean(challenge9Yes?.checked || challenge9No?.checked);
      const pathBComplete = challenge9No?.checked ? Boolean(feePaid?.checked) : true;
      const infoIsOpen = Boolean(infoSection && !infoSection.classList.contains("hidden"));

      return choseCommitment && choseChallenge9 && pathBComplete && infoIsOpen;
    };

    const hasAllVisibleRequiredFieldsValid = () => {
      const requiredVisibleFields = Array.from(form.querySelectorAll<ValidField>("input, select, textarea"))
        .filter((field) => {
          if (!field.willValidate || !field.required) {
            return false;
          }

          if (field instanceof HTMLInputElement && field.type === "hidden") {
            return false;
          }

          return isElementVisible(field);
        })
        .map((field) => {
          syncSpecialFieldValidity(field);
          return field;
        });

      return requiredVisibleFields.length > 0 && requiredVisibleFields.every((field) => field.checkValidity());
    };

    const refreshSubmitAvailability = () => {
      const workflowOpen = isSubmitWorkflowOpen();

      if (submitActions) {
        submitActions.classList.toggle("hidden", !workflowOpen);
      }

      if (!workflowOpen || isSubmitting || !hasAllVisibleRequiredFieldsValid()) {
        submitBtn.setAttribute("disabled", "true");
        return;
      }

      submitBtn.removeAttribute("disabled");
    };

    const interactiveFields = form.querySelectorAll<ValidField>("input, select, textarea");
    interactiveFields.forEach((field) => {
      field.addEventListener("input", () => {
        syncSpecialFieldValidity(field);
        clearFieldError(field);
        refreshSubmitAvailability();
      });

      field.addEventListener("change", () => {
        syncSpecialFieldValidity(field);
        clearFieldError(field);
        refreshSubmitAvailability();
      });

      field.addEventListener("blur", () => {
        syncSpecialFieldValidity(field);
        if (isElementVisible(field) && !field.checkValidity()) {
          setFieldError(field, getCustomFieldMessage(field));
        }
        refreshSubmitAvailability();
      });
    });

    refreshSubmitAvailability();

    if (submitSink instanceof HTMLIFrameElement) {
      submitSink.addEventListener("load", () => {
        if (!submitted) {
          return;
        }

        form.classList.add("hidden");
        successCard.classList.remove("hidden");
        submitted = false;
      });
    }

    // Commitment selection handlers
    if (commitYes && commitNo && challenge9Section && pathABanner && feeSection && infoSection && challenge9Yes && challenge9No) {
      commitYes.addEventListener("change", () => {
        if (commitYes.checked) {
          challenge9Section.classList.remove("hidden");
          updateFlowAnnouncement("Đã mở bước chọn kết quả Challenge 9.");
          updateStepIndicators();
          // Re-trigger the selected option if any
          if (challenge9Yes.checked) challenge9Yes.dispatchEvent(new Event('change'));
          if (challenge9No.checked) challenge9No.dispatchEvent(new Event('change'));
        }
        refreshSubmitAvailability();
      });

      commitNo.addEventListener("change", () => {
        if (commitNo.checked) {
          challenge9Section.classList.add("hidden");
          pathABanner.classList.add("hidden");
          feeSection.classList.add("hidden");
          infoSection.classList.add("hidden");
          updateFlowAnnouncement("Bạn đã chọn cần cân nhắc thêm. Các bước đăng ký phía dưới đang được ẩn.");
          updateStepIndicators();
        }
        refreshSubmitAvailability();
      });
    }

    // Challenge 9 selection handlers
    if (challenge9Yes && challenge9No && pathABanner && infoSection && feeSection && feePaid && feeUnpaid) {
      challenge9Yes.addEventListener("change", () => {
        if (challenge9Yes.checked) {
          pathABanner.classList.remove("hidden");
          infoSection.classList.remove("hidden");
          feeSection.classList.add("hidden");
          if (feeRequiredMark) {
            feeRequiredMark.classList.add("hidden");
          }
          
          // Remove required from fee status
          feePaid.removeAttribute("required");
          feeUnpaid.removeAttribute("required");
          updateFlowAnnouncement("Bạn đang ở Path A. Đã mở phần tự động điền và thông tin đăng ký.");
          updateStepIndicators();

          // Pre-load excellence completers data
          loadExcellenceCompleters();
        }
        refreshSubmitAvailability();
      });

      challenge9No.addEventListener("change", () => {
        if (challenge9No.checked) {
          pathABanner.classList.add("hidden");
          feeSection.classList.remove("hidden");
          if (feeRequiredMark) {
            feeRequiredMark.classList.remove("hidden");
          }
          
          // Add required back to fee status
          feePaid.setAttribute("required", "true");
          feeUnpaid.setAttribute("required", "true");

          // Chỉ mở form thông tin khi người dùng đã xác nhận đóng phí.
          if (!feePaid.checked) {
            infoSection.classList.add("hidden");
          } else {
            infoSection.classList.remove("hidden");
          }
          updateFlowAnnouncement("Bạn đang ở Path B. Vui lòng chọn trạng thái đóng phí để tiếp tục.");
          updateStepIndicators();

          // Reset lookup state
          if (lookupMessage) {
            lookupMessage.classList.add("hidden");
          }
          if (discordPickerSearch) {
            discordPickerSearch.value = "";
          }
          resetPickerLabel();
        }
        refreshSubmitAvailability();
      });
    }

    // Fee status selection handlers (Path B)
    if (feePaid && feeUnpaid && infoSection) {
      feePaid.addEventListener("change", () => {
        if (feePaid.checked) {
          infoSection.classList.remove("hidden");
          updateFlowAnnouncement("Đã mở các trường thông tin sau khi chọn trạng thái đóng phí.");
          updateStepIndicators();
        }
        refreshSubmitAvailability();
      });
      feeUnpaid.addEventListener("change", () => {
        if (feeUnpaid.checked) {
          infoSection.classList.add("hidden");
          updateFlowAnnouncement("Bạn cần đóng phí trước khi mở phần nhập thông tin đăng ký.");
          updateStepIndicators();
        }
        refreshSubmitAvailability();
      });
    }

    if (discordPickerTrigger && discordPickerModal && discordPickerClose && discordPickerOverlay) {
      discordPickerTrigger.addEventListener("click", async () => {
        const users = await loadExcellenceCompleters();
        if (!users) {
          return;
        }

        pickerFilteredCompleters = [...users];
        renderPickerList();
        if (discordPickerSearch) {
          discordPickerSearch.value = "";
        }
        openPickerModal();
      });

      discordPickerClose.addEventListener("click", closePickerModal);
      discordPickerOverlay.addEventListener("click", closePickerModal);

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !discordPickerModal.classList.contains("hidden")) {
          closePickerModal();
        }
      });
    }

    if (discordPickerSearch && discordPickerModal && discordPickerList) {
      discordPickerSearch.addEventListener("input", () => {
        filterPickerList(discordPickerSearch.value);
      });

      discordPickerModal.addEventListener("keydown", (event) => {
        const options = Array.from(discordPickerList.querySelectorAll<HTMLButtonElement>(".picker-option"));
        const currentIndex = options.indexOf(document.activeElement as HTMLButtonElement);
        const isSearchFocused = document.activeElement === discordPickerSearch;

        if (event.key === "ArrowDown") {
          event.preventDefault();
          if (options.length === 0) return;
          if (isSearchFocused || currentIndex === -1) {
            options[0].focus();
          } else if (currentIndex < options.length - 1) {
            options[currentIndex + 1].focus();
          }
        } else if (event.key === "ArrowUp") {
          event.preventDefault();
          if (options.length === 0) return;
          if (currentIndex > 0) {
            options[currentIndex - 1].focus();
          } else if (currentIndex === 0) {
            discordPickerSearch.focus();
          }
        } else if (event.key === "Enter" && isSearchFocused) {
          event.preventDefault();
          if (options.length > 0) {
            options[0].click();
          }
        }
      });
    }

    form.addEventListener("submit", (event) => {
      event.preventDefault();

      if (isSubmitting) {
        return;
      }

      if (!isSubmitWorkflowOpen()) {
        message.textContent = "Vui lòng hoàn thành các bước workflow trước khi gửi.";
        message.className = "helper warning";
        refreshSubmitAvailability();
        return;
      }

      if (!hasAllVisibleRequiredFieldsValid()) {
        message.textContent = "Vui lòng điền đầy đủ và hợp lệ các trường bắt buộc trước khi gửi.";
        message.className = "helper warning";
        refreshSubmitAvailability();
        return;
      }

      if (!validateVisibleFields()) {
        message.textContent = "Vui lòng kiểm tra các trường đang báo lỗi.";
        message.className = "helper error";
        refreshSubmitAvailability();
        return;
      }

      isSubmitting = true;
      submitBtn.setAttribute("disabled", "true");
      submitBtnLabel.textContent = "Đang gửi...";
      submitBtnSpinner.classList.remove("hidden");
      message.textContent = "Đang gửi dữ liệu lên Google Form...";
      message.className = "helper";

      try {
        submitted = true;
        form.submit();
      } catch {
        message.textContent =
          "Không thể gửi lúc này. Thử lại hoặc bấm Mở lại form gốc để điền trực tiếp.";
        message.className = "helper error";
        submitted = false;
      } finally {
        isSubmitting = false;
        submitBtnLabel.textContent = "Gửi đăng ký";
        submitBtnSpinner.classList.add("hidden");
        refreshSubmitAvailability();
      }
    });
  }
</script>

